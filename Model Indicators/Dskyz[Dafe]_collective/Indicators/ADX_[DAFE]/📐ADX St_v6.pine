    'Classic Terminal' => #000000
    => #0A0A14
frameColor = switch colorTheme
    'Neon Tokyo' => #00DDFF
    'Ocean Depths' => #1E90FF
    'Forest Canopy' => #6B8E23
    'Arctic Aurora' => #7B68EE
    'Sunset Blaze' => #FF8C00
    'Quantum Purple' => #8844FF
    'Classic Terminal' => #333333
    => #00DDFF
    // ═══════════════════════════════════════════════════════════════════════════════════════════════════════
    // 📐 CORE ADX CALCULATIONS
    // ═══════════════════════════════════════════════════════════════════════════════════════════════════════
f_smooth(src, len, type) =>
    switch type
        'RMA' => ta.rma(src, len)
        'EMA' => ta.ema(src, len)
        'SMA' => ta.sma(src, len)
        'WMA' => ta.wma(src, len)
        => ta.rma(src, len)
trueRange = math.max(math.max(high - low, math.abs(high - close[1])), math.abs(low - close[1]))
upMove = high - high[1]
downMove = low[1] - low
plusDM = upMove > downMove and upMove > 0 ? upMove : 0.0
minusDM = downMove > upMove and downMove > 0 ? downMove : 0.0
smoothTR = f_smooth(trueRange, diLen, smoothType)
smoothPlusDM = f_smooth(plusDM, diLen, smoothType)
smoothMinusDM = f_smooth(minusDM, diLen, smoothType)
plusDI = smoothTR != 0 ? 100 * smoothPlusDM / smoothTR : 0.0
minusDI = smoothTR != 0 ? 100 * smoothMinusDM / smoothTR : 0.0
dx = plusDI + minusDI != 0 ? 100 * math.abs(plusDI - minusDI) / (plusDI + minusDI) : 0.0
adx = f_smooth(dx, adxLen, smoothType)
atr14 = ta.atr(14)
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
// 📈 CURVATURE & META CALCULATIONS
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
adxVelocity = adx - adx[1]
adxVelocitySmooth = f_smooth(adxVelocity, curvatureSmooth, 'EMA')
adxAcceleration = adx - 2 * adx[1] + adx[2]
adxAccelerationSmooth = f_smooth(adxAcceleration, curvatureSmooth, 'EMA')
rsiOfADX = ta.rsi(adx, rsiOfADXLen)
adxHigh = ta.highest(adx, 5)
adxLow = ta.lowest(adx, 5)
adxTR = math.max(adxHigh - adxLow, math.max(math.abs(adxHigh - adx[1]), math.abs(adxLow - adx[1])))
adxUpMove = adxHigh - adxHigh[1]
adxDownMove = adxLow[1] - adxLow
adxPlusDM = adxUpMove > adxDownMove and adxUpMove > 0 ? adxUpMove : 0.0
adxMinusDM = adxDownMove > adxUpMove and adxDownMove > 0 ? adxDownMove : 0.0
smoothADXTR = ta.rma(adxTR, 7)
smoothADXPlusDM = ta.rma(adxPlusDM, 7)
smoothADXMinusDM = ta.rma(adxMinusDM, 7)
adxPlusDI = smoothADXTR != 0 ? 100 * smoothADXPlusDM / smoothADXTR : 0.0
adxMinusDI = smoothADXTR != 0 ? 100 * smoothADXMinusDM / smoothADXTR : 0.0
adxDX = adxPlusDI + adxMinusDI != 0 ? 100 * math.abs(adxPlusDI - adxMinusDI) / (adxPlusDI + adxMinusDI) : 0.0
metaADX = ta.rma(adxDX, 7)
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
// 📊 Z-SCORE NORMALIZATION
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
adxMean = ta.sma(adx, zScoreLen)
adxStdev = ta.stdev(adx, zScoreLen)
adxZScore = adxStdev != 0 ? (adx - adxMean) / adxStdev : 0.0
velMean = ta.sma(adxVelocitySmooth, zScoreLen)
velStdev = ta.stdev(adxVelocitySmooth, zScoreLen)
velocityZScore = velStdev != 0 ? (adxVelocitySmooth - velMean) / velStdev : 0.0
accelMean = ta.sma(adxAccelerationSmooth, zScoreLen)
accelStdev = ta.stdev(adxAccelerationSmooth, zScoreLen)
curvatureZScore = accelStdev != 0 ? (adxAccelerationSmooth - accelMean) / accelStdev : 0.0
compositeCurvature = enableZScore ? (curvatureZScore + velocityZScore * 0.5) / 1.5 : adxAccelerationSmooth
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
// 🔄 DIVERGENCE DETECTION
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
priceSlope = (close - close[divLookback]) / divLookback
adxSlope = (adx - adx[divLookback]) / divLookback
priceStdevDiv = ta.stdev(close - close[1], divLookback)
adxStdevDiv = ta.stdev(adx - adx[1], divLookback)
normPriceSlope = priceStdevDiv != 0 ? priceSlope / priceStdevDiv : 0.0
normADXSlope = adxStdevDiv != 0 ? adxSlope / adxStdevDiv : 0.0
bullishDivergence = enableDivergence and normPriceSlope < -divSensitivity and normADXSlope > divSensitivity
bearishDivergence = enableDivergence and normPriceSlope > divSensitivity and normADXSlope < -divSensitivity
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
// 🌙 TREND PHASE DETECTION
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
var string PHASE_DORMANT = 'DORMANT'
var string PHASE_IGNITION = 'IGNITION'
var string PHASE_ACCELERATION = 'ACCELERATION'
var string PHASE_MATURE = 'MATURE'
var string PHASE_EXHAUSTION = 'EXHAUSTION'
var string PHASE_DECLINE = 'DECLINE'
f_detectPhase() =>
    string phase = PHASE_DORMANT
    if adx < lowADXThreshold and math.abs(adxVelocitySmooth) < 1.0
        phase := PHASE_DORMANT
        phase
    else if adx < 25 and adxVelocitySmooth > 0 and curvatureZScore > ignitionThreshold
        phase := PHASE_IGNITION
        phase
    else if adx >= lowADXThreshold and adx < highADXThreshold and adxVelocitySmooth > 0.5 and adxAccelerationSmooth > 0
        phase := PHASE_ACCELERATION
        phase
    else if adx >= highADXThreshold and adxVelocitySmooth >= 0 and adxAccelerationSmooth <= 0
        phase := PHASE_MATURE
        phase
    else if adx >= highADXThreshold and curvatureZScore < -exhaustionThreshold
        phase := PHASE_EXHAUSTION
        phase
    else if adxVelocitySmooth < -0.5 and adx > lowADXThreshold
        phase := PHASE_DECLINE
        phase
    phase
currentPhase = f_detectPhase()
var string confirmedPhase = PHASE_DORMANT
var int phaseCounter = 0
if currentPhase == currentPhase[1]
    phaseCounter := phaseCounter + 1
    phaseCounter
else
    phaseCounter := 1
    phaseCounter
if phaseCounter >= confirmBars
    confirmedPhase := currentPhase
    confirmedPhase
phaseChanged = confirmedPhase != confirmedPhase[1]
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
// 🎯 SIGNAL DETECTION
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
var int lastSignalBar = 0
barsSinceLastSignal = bar_index - lastSignalBar
allowNewSignal = barsSinceLastSignal >= minBarsBetweenSignals
trendIgniting = confirmedPhase == PHASE_IGNITION and confirmedPhase[1] != PHASE_IGNITION
trendExhausting = confirmedPhase == PHASE_EXHAUSTION and confirmedPhase[1] != PHASE_EXHAUSTION
trendAccelerating = confirmedPhase == PHASE_ACCELERATION and confirmedPhase[1] == PHASE_IGNITION
curvatureSpikeUp = curvatureZScore > zThreshold and curvatureZScore[1] <= zThreshold
curvatureSpikeDown = curvatureZScore < -zThreshold and curvatureZScore[1] >= -zThreshold
inIgnitionZone = adx < lowADXThreshold and adxVelocitySmooth > 0 and curvatureZScore > ignitionThreshold * 0.5
inExhaustionZone = adx > highADXThreshold * 0.8 and curvatureZScore < -exhaustionThreshold * 0.5
bullishBias = plusDI > minusDI
bearishBias = minusDI > plusDI
signalStrength = (trendIgniting ? 30.0 : 0.0) + (trendExhausting ? 30.0 : 0.0) + (curvatureSpikeUp or curvatureSpikeDown ? 20.0 : 0.0) + (math.abs(curvatureZScore) > zThreshold ? 10.0 : 0.0)
ignBullSignal = enableSignals and allowNewSignal and trendIgniting and bullishBias
ignBearSignal = enableSignals and allowNewSignal and trendIgniting and bearishBias
exhBullSignal = enableSignals and allowNewSignal and trendExhausting and bullishBias
exhBearSignal = enableSignals and allowNewSignal and trendExhausting and bearishBias
accBullSignal = enableSignals and allowNewSignal and trendAccelerating and bullishBias
accBearSignal = enableSignals and allowNewSignal and trendAccelerating and bearishBias
if ignBullSignal or ignBearSignal or exhBullSignal or exhBearSignal or accBullSignal or accBearSignal
    lastSignalBar := bar_index
    lastSignalBar
divBullSignal = enableDivergence and bullishDivergence
divBearSignal = enableDivergence and bearishDivergence
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
// 🎯 KILL ZONE LABELS
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
var label ignitionZoneLabel = na
var label exhaustionZoneLabel = na
var bool inIgnZone = false
var bool inExhZone = false
if enableKillZones
    if inIgnitionZone and not inIgnZone
        inIgnZone := true
        ignitionZoneLabel := label.new(bar_index, low, '⚡ IGNITION ZONE', color = color.new(color.white, 100), textcolor = ignitionBullColor, style = label.style_label_up, size = size.normal, xloc = xloc.bar_index, force_overlay = true)
        ignitionZoneLabel
    else if not inIgnitionZone and inIgnZone
        inIgnZone := false
        if not na(ignitionZoneLabel)
            label.delete(ignitionZoneLabel)
    if inExhaustionZone and not inExhZone
        inExhZone := true
        exhaustionZoneLabel := label.new(bar_index, high, '🔥 EXHAUSTION ZONE', color = color.new(color.white, 100), textcolor = exhaustionBullColor, style = label.style_label_down, size = size.normal, xloc = xloc.bar_index, force_overlay = true)
        exhaustionZoneLabel
    else if not inExhaustionZone and inExhZone
        inExhZone := false
        if not na(exhaustionZoneLabel)
            label.delete(exhaustionZoneLabel)
    if inIgnZone and not na(ignitionZoneLabel)
        label.set_x(ignitionZoneLabel, bar_index)
        label.set_y(ignitionZoneLabel, low)
    if inExhZone and not na(exhaustionZoneLabel)
        label.set_x(exhaustionZoneLabel, bar_index)
        label.set_y(exhaustionZoneLabel, high)
        // ═══════════════════════════════════════════════════════════════════════════════════════════════════════
        // 📏 SIGNAL LINE MANAGEMENT
        // ═══════════════════════════════════════════════════════════════════════════════════════════════════════
f_getLineStyle() =>
    switch lineStyle
        'Solid' => line.style_solid
        'Dashed' => line.style_dashed
        'Dotted' => line.style_dotted
        => line.style_dashed
type SignalLineData
	line entryLine
	line slLine
	line tp1Line
	line tp2Line
	line tp3Line
	label lbl
	int birthBar
	float entryPrice
	float slPrice
	float tp1Price
	float tp2Price
	float tp3Price
	bool isLong
	string signalType
	color signalColor
	bool tp1Hit
	bool tp2Hit
	bool isComplete
var array<SignalLineData> activeSignals = array.new<SignalLineData>()
var int completedBullWin = 0
var int completedBullLoss = 0
var int completedBearWin = 0
var int completedBearLoss = 0
var array<int> indicesToRemove = array.new<int>()
f_createSignalLines(float price, bool isLong, string sigType, color sigColor) =>
    if showSignalLines and array.size(activeSignals) < 20
        atrVal = atr14
        slPrice = isLong ? price - atrVal * lineSLMultiplier : price + atrVal * lineSLMultiplier
        tp1Price = isLong ? price + atrVal * lineTP1Multiplier : price - atrVal * lineTP1Multiplier
        tp2Price = isLong ? price + atrVal * lineTP2Multiplier : price - atrVal * lineTP2Multiplier
        tp3Price = isLong ? price + atrVal * lineTP3Multiplier : price - atrVal * lineTP3Multiplier
        lstyle = f_getLineStyle()
        entryLn = line.new(bar_index, price, bar_index + lineMaxBars, price, color = sigColor, width = lineWidth, style = lstyle, force_overlay = true)
        slLn = showSLTPLines ? line.new(bar_index, slPrice, bar_index + lineMaxBars, slPrice, color = slLineColor, width = 1, style = line.style_dotted, force_overlay = true) : na
        tp1Ln = showSLTPLines ? line.new(bar_index, tp1Price, bar_index + lineMaxBars, tp1Price, color = color.new(tpLineColor, 60), width = 1, style = line.style_dotted, force_overlay = true) : na
        tp2Ln = showSLTPLines ? line.new(bar_index, tp2Price, bar_index + lineMaxBars, tp2Price, color = color.new(tpLineColor, 40), width = 1, style = line.style_dotted, force_overlay = true) : na
        tp3Ln = showSLTPLines ? line.new(bar_index, tp3Price, bar_index + lineMaxBars, tp3Price, color = tpLineColor, width = 1, style = line.style_dotted, force_overlay = true) : na
        lbl = showLineLabels ? label.new(bar_index + lineMaxBars + 2, price, sigType, color = color.new(color.white, labelTransparency), textcolor = sigColor, style = label.style_label_left, size = size.tiny, force_overlay = true) : na
        sigData = SignalLineData.new(entryLn, slLn, tp1Ln, tp2Ln, tp3Ln, lbl, bar_index, price, slPrice, tp1Price, tp2Price, tp3Price, isLong, sigType, sigColor, false, false, false)
        array.push(activeSignals, sigData)
    true
    // ═══════════════════════════════════════════════════════════════════════════════════════════════════════
    // 📏 SIGNAL LINE PROCESSING 
    // ═══════════════════════════════════════════════════════════════════════════════════════════════════════
array.clear(indicesToRemove)
if array.size(activeSignals) > 0
    for i = 0 to array.size(activeSignals) - 1 by 1
        sig = array.get(activeSignals, i)
        age = bar_index - sig.birthBar
        expired = age > lineMaxBars
        if sig.isLong
            if high >= sig.tp1Price and not sig.tp1Hit
                sig.tp1Hit := true
                sig.tp1Hit
            if high >= sig.tp2Price and not sig.tp2Hit
                sig.tp2Hit := true
                sig.tp2Hit
        else
            if low <= sig.tp1Price and not sig.tp1Hit
                sig.tp1Hit := true
                sig.tp1Hit
            if low <= sig.tp2Price and not sig.tp2Hit
                sig.tp2Hit := true
                sig.tp2Hit
        slHit = sig.isLong ? low <= sig.slPrice : high >= sig.slPrice
        finalTPHit = sig.isLong ? high >= sig.tp3Price : low <= sig.tp3Price
        priceBreak = sig.isLong ? close < sig.entryPrice and close[1] >= sig.entryPrice : close > sig.entryPrice and close[1] <= sig.entryPrice
        shouldClose = expired or slHit or finalTPHit or priceBreak and age > 3
        if shouldClose
            isWin = finalTPHit or sig.tp2Hit or sig.tp1Hit and not slHit
            if sig.isLong
                if isWin
                    completedBullWin := bar_index
                    completedBullWin
                else
                    completedBullLoss := bar_index
                    completedBullLoss
            else
                if isWin
                    completedBearWin := bar_index
                    completedBearWin
                else
                    completedBearLoss := bar_index
                    completedBearLoss
            line.delete(sig.entryLine)
            if not na(sig.slLine)
                line.delete(sig.slLine)
            if not na(sig.tp1Line)
                line.delete(sig.tp1Line)
            if not na(sig.tp2Line)
                line.delete(sig.tp2Line)
            if not na(sig.tp3Line)
                line.delete(sig.tp3Line)
            if not na(sig.lbl)
                label.delete(sig.lbl)
            array.push(indicesToRemove, i)
        else
            extendBars = math.min(lineMaxBars - age, 20)
            newX2 = bar_index + extendBars
            line.set_x2(sig.entryLine, newX2)
            if not na(sig.slLine)
                line.set_x2(sig.slLine, newX2)
            if not na(sig.tp1Line)
                line.set_x2(sig.tp1Line, newX2)
                if sig.tp1Hit
                    line.set_color(sig.tp1Line, color.new(tpLineColor, 90))
            if not na(sig.tp2Line)
                line.set_x2(sig.tp2Line, newX2)
                if sig.tp2Hit
                    line.set_color(sig.tp2Line, color.new(tpLineColor, 90))
            if not na(sig.tp3Line)
                line.set_x2(sig.tp3Line, newX2)
            if not na(sig.lbl)
                label.set_x(sig.lbl, newX2 + 2)
                tpStatus = sig.tp2Hit ? ' ✓✓' : sig.tp1Hit ? ' ✓' : ''
                label.set_text(sig.lbl, sig.signalType + tpStatus)
if array.size(indicesToRemove) > 0
    for i = array.size(indicesToRemove) - 1 to 0 by 1
        idx = array.get(indicesToRemove, i)
        if idx < array.size(activeSignals)
            array.remove(activeSignals, idx)
if ignBullSignal
    f_createSignalLines(close, true, '⚡IGN', ignitionBullColor)
if ignBearSignal
    f_createSignalLines(close, false, '⚡IGN', ignitionBearColor)
if exhBullSignal
    f_createSignalLines(close, true, '🔥EXH', exhaustionBullColor)
if exhBearSignal
    f_createSignalLines(close, false, '🔥EXH', exhaustionBearColor)
if accBullSignal
    f_createSignalLines(close, true, '🚀ACC', accelBullColor)
if accBearSignal
    f_createSignalLines(close, false, '🚀ACC', accelBearColor)
if divBullSignal
    f_createSignalLines(close, true, '🔄DIV', divBullColor)
if divBearSignal
    f_createSignalLines(close, false, '🔄DIV', divBearColor)
    // ═════════════════════════════════════════════════════════════════════════════
    // MAIN CHART SHAPES
    // ═════════════════════════════════════════════════════════════════════════════
plotshape(ignBullSignal, title = '▲ IGNITION', style = shape.triangleup, location = location.belowbar, color = color.new(ignitionBullColor, 0), size = size.tiny, force_overlay = true)
plotshape(ignBearSignal, title = '▼ IGNITION', style = shape.triangledown, location = location.abovebar, color = color.new(ignitionBearColor, 0), size = size.tiny, force_overlay = true)
plotshape(exhBullSignal, title = '▲ EXHAUSTION', style = shape.triangleup, location = location.belowbar, color = color.new(exhaustionBullColor, 0), size = size.tiny, force_overlay = true)
plotshape(exhBearSignal, title = '▼ EXHAUSTION', style = shape.triangledown, location = location.abovebar, color = color.new(exhaustionBearColor, 0), size = size.tiny, force_overlay = true)
plotshape(accBullSignal, title = '🚀 ACCELERATION', style = shape.triangleup, location = location.belowbar, color = color.new(accelBullColor, 0), size = size.tiny, force_overlay = true)
plotshape(accBearSignal, title = '🚀 ACCELERATION', style = shape.triangledown, location = location.abovebar, color = color.new(accelBearColor, 0), size = size.tiny, force_overlay = true)
plotshape(divBullSignal, title = '◇ DIVERGENCE ↑', style = shape.xcross, location = location.belowbar, color = divBullColor, size = size.tiny, force_overlay = true)
plotshape(divBearSignal, title = '◇ DIVERGENCE ↓', style = shape.xcross, location = location.abovebar, color = divBearColor, size = size.tiny, force_overlay = true)
completedBullWinShape = bar_index == completedBullWin and completedBullWin > 0
completedBullLossShape = bar_index == completedBullLoss and completedBullLoss > 0
completedBearWinShape = bar_index == completedBearWin and completedBearWin > 0
completedBearLossShape = bar_index == completedBearLoss and completedBearLoss > 0
plotshape(completedBullWinShape, title = '✓ Win', style = shape.labelup, location = location.belowbar, color = color.new(color.white, 100), text = '✓', textcolor = #00FF00, size = size.tiny, force_overlay = true)
plotshape(completedBullLossShape, title = '✗ Loss', style = shape.labelup, location = location.belowbar, color = color.new(color.white, 100), text = '✗', textcolor = #FF0000, size = size.tiny, force_overlay = true)
plotshape(completedBearWinShape, title = '✓ Win', style = shape.labeldown, location = location.abovebar, color = color.new(color.white, 100), text = '✓', textcolor = #00FF00, size = size.tiny, force_overlay = true)
plotshape(completedBearLossShape, title = '✗ Loss', style = shape.labeldown, location = location.abovebar, color = color.new(color.white, 100), text = '✗', textcolor = #FF0000, size = size.tiny, force_overlay = true)
// ═════════════════════════════════════════════════════════════════════════════
// LOWER PANE (ADX LINE) SIGNALS
// ═════════════════════════════════════════════════════════════════════════════
var color circleColor = na
var float circleValue = na
var color crossColor = na
var float crossValue = na
if showDotsOnADX
    if ignBullSignal
        circleColor := ignitionBullColor
        circleValue := adx
        circleValue
    else if ignBearSignal
        circleColor := ignitionBearColor
        circleValue := adx
        circleValue
    else if exhBullSignal
        circleColor := exhaustionBullColor
        circleValue := adx
        circleValue
    else if exhBearSignal
        circleColor := exhaustionBearColor
        circleValue := adx
        circleValue
    else if accBullSignal
        circleColor := accelBullColor
        circleValue := adx
        circleValue
    else if accBearSignal
        circleColor := accelBearColor
        circleValue := adx
        circleValue
    else if curvatureSpikeUp
        circleColor := spikeBullColor
        circleValue := adx
        circleValue
    else if curvatureSpikeDown
        circleColor := spikeBearColor
        circleValue := adx
        circleValue
    else
        circleValue := na
        circleColor := na
        circleColor
    if bullishDivergence
        crossColor := divBullColor
        crossValue := adx
        crossValue
    else if bearishDivergence
        crossColor := divBearColor
        crossValue := adx
        crossValue
    else
        crossValue := na
        crossColor := na
        crossColor
else
    circleValue := na
    crossValue := na
    crossValue
plot(circleValue, 'Signal Circles', color = circleColor, style = plot.style_circles, linewidth = 4)
plot(crossValue, 'Signal Crosses', color = crossColor, style = plot.style_cross, linewidth = 3)
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
// 🧪 OPTIMIZER ENGINE
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
var float optEntryPrice = na
var bool optInTrade = false
var bool optIsLong = false
var int btTotalTrades = 0
var int btWins = 0
var float btGrossProfit = 0.0
var float btGrossLoss = 0.0
strongBuySignal = enableSignals and (trendIgniting or curvatureSpikeUp) and bullishBias
strongSellSignal = enableSignals and (trendIgniting or curvatureSpikeUp) and bearishBias
exitSignal = trendExhausting or curvatureSpikeDown
if optMode
    if optInTrade
        slPrice = optIsLong ? optEntryPrice - atr14 * optSL : optEntryPrice + atr14 * optSL
        tpPrice = optIsLong ? optEntryPrice + atr14 * optTP : optEntryPrice - atr14 * optTP
        hitSL = optIsLong ? low <= slPrice : high >= slPrice
        hitTP = optIsLong ? high >= tpPrice : low <= tpPrice
        shouldExit = optIsLong ? exitSignal and bearishBias : exitSignal and bullishBias
        if hitSL or hitTP or shouldExit
            exitP = hitTP ? tpPrice : hitSL ? slPrice : close
            pnl = optIsLong ? exitP - optEntryPrice : optEntryPrice - exitP
            btTotalTrades := btTotalTrades + 1
            if pnl > 0
                btWins := btWins + 1
                btGrossProfit := btGrossProfit + pnl
                btGrossProfit
            else
                btGrossLoss := btGrossLoss + math.abs(pnl)
                btGrossLoss
            optInTrade := false
            optEntryPrice := na
            optEntryPrice
    if not optInTrade
        if strongBuySignal
            optInTrade := true
            optIsLong := true
            optEntryPrice := close
            optEntryPrice
        else if strongSellSignal
            optInTrade := true
            optIsLong := false
            optEntryPrice := close
            optEntryPrice
btWinRate = btTotalTrades > 0 ? btWins / btTotalTrades * 100 : 0.0
btProfitFactor = btGrossLoss > 0 ? btGrossProfit / btGrossLoss : btGrossProfit > 0 ? 99.9 : 0.0
btExpectancy = btTotalTrades > 0 ? (btGrossProfit - btGrossLoss) / btTotalTrades : 0.0
stabilityPoints = 0
stabilityPoints := stabilityPoints + (btWinRate >= 55 ? 25 : btWinRate >= 50 ? 15 : btWinRate >= 45 ? 5 : 0)
stabilityPoints := stabilityPoints + (btExpectancy > 0.5 ? 25 : btExpectancy > 0.1 ? 15 : btExpectancy > 0 ? 5 : 0)
stabilityPoints := stabilityPoints + (btTotalTrades >= 30 ? 25 : btTotalTrades >= 20 ? 15 : btTotalTrades >= 10 ? 5 : 0)
stabilityPoints := stabilityPoints + (btProfitFactor >= 1.5 ? 25 : btProfitFactor >= 1.2 ? 15 : btProfitFactor >= 1.0 ? 5 : 0)
robustText = stabilityPoints >= 80 ? 'ROBUST' : stabilityPoints >= 60 ? 'STABLE' : stabilityPoints >= 40 ? 'FRAGILE' : 'OVERFIT'
robustCol = stabilityPoints >= 80 ? bullColor : stabilityPoints >= 60 ? accentColor1 : stabilityPoints >= 40 ? accentColor3 : bearColor
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
// 🌀 QUANTUM ADX BANDS (Lower Pane)
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
phaseColor = switch confirmedPhase
    PHASE_DORMANT => neutralColor
    PHASE_IGNITION => ignitionBullColor
    PHASE_ACCELERATION => bullColor
    PHASE_MATURE => accentColor3
    PHASE_EXHAUSTION => exhaustionBullColor
    PHASE_DECLINE => bearColor
    => neutralColor
curvatureInfluence = 1.0 + math.abs(curvatureZScore) / 4.0
adxInfluence = adx / 50
volatilityMultiplier = curvatureInfluence * (0.5 + adxInfluence * 0.5)
basis = ta.ema(adx, 21)
adx_volatility = ta.stdev(adx, 20)
baseWidth = adx_volatility * vortexSensitivity * volatilityMultiplier
trendUp = adx > basis
bullPhaseColor = switch confirmedPhase
    PHASE_IGNITION => color.new(ignitionBullColor, vortexTransparency)
    PHASE_ACCELERATION => color.new(bullColor, vortexTransparency - 5)
    PHASE_MATURE => color.new(accentColor3, vortexTransparency)
    => color.new(bullColor, vortexTransparency + 5)
bearPhaseColor = switch confirmedPhase
    PHASE_EXHAUSTION => color.new(exhaustionBullColor, vortexTransparency)
    PHASE_DECLINE => color.new(bearColor, vortexTransparency - 5)
    => color.new(bearColor, vortexTransparency + 5)
band1_val = switch vortexMode
    'Triple Layer' => basis + baseWidth * 2.0
    'Fractal Cloud' => basis + adx_volatility * vortexSensitivity * 2.5
    'Momentum Tunnel' => basis + baseWidth * 1.8
    'Phase Spectrum' => basis + adx_volatility * vortexSensitivity * 1.5
    => basis + baseWidth * 2.0
band2_val = switch vortexMode
    'Triple Layer' => basis + baseWidth * 1.2
    'Fractal Cloud' => basis + adx_volatility * vortexSensitivity * 1.5
    'Momentum Tunnel' => basis + baseWidth * 0.6
    'Phase Spectrum' => basis + adx_volatility * vortexSensitivity * 1.0
    => basis + baseWidth * 1.2
band3_val = switch vortexMode
    'Triple Layer' => basis + baseWidth * 0.5
    'Fractal Cloud' => basis + adx_volatility * vortexSensitivity * 0.5
    'Momentum Tunnel' => basis + baseWidth * 0.15
    'Phase Spectrum' => basis + adx_volatility * vortexSensitivity * 0.5
    => basis + baseWidth * 0.5
band4_val = switch vortexMode
    'Triple Layer' => basis - baseWidth * 0.5
    'Fractal Cloud' => basis - adx_volatility * vortexSensitivity * 0.5
    'Momentum Tunnel' => basis - baseWidth * 0.15
    'Phase Spectrum' => basis - adx_volatility * vortexSensitivity * 0.5
    => basis - baseWidth * 0.5
band5_val = switch vortexMode
    'Triple Layer' => basis - baseWidth * 1.2
    'Fractal Cloud' => basis - adx_volatility * vortexSensitivity * 1.5
    'Momentum Tunnel' => basis - baseWidth * 0.6
    'Phase Spectrum' => basis - adx_volatility * vortexSensitivity * 1.0
    => basis - baseWidth * 1.2
band6_val = switch vortexMode
    'Triple Layer' => basis - baseWidth * 2.0
    'Fractal Cloud' => basis - adx_volatility * vortexSensitivity * 2.5
    'Momentum Tunnel' => basis - baseWidth * 1.8
    'Phase Spectrum' => basis - adx_volatility * vortexSensitivity * 1.5
    => basis - baseWidth * 2.0
p1 = plot(showVortex ? band1_val : na, 'Band 1', color = color.new(phaseColor, 70), linewidth = 1)
p2 = plot(showVortex ? band2_val : na, 'Band 2', color = color.new(phaseColor, 50), linewidth = math.max(1, vortexMode == 'Momentum Tunnel' ? 1 : 2))
p3 = plot(showVortex ? band3_val : na, 'Band 3', color = vortexMode == 'Momentum Tunnel' ? color.new(phaseColor, 20) : phaseColor, linewidth = math.max(1, vortexMode == 'Momentum Tunnel' ? 4 : 2))
p4 = plot(showVortex ? band4_val : na, 'Band 4', color = vortexMode == 'Momentum Tunnel' ? color.new(phaseColor, 20) : phaseColor, linewidth = math.max(1, vortexMode == 'Momentum Tunnel' ? 4 : 2))
p5 = plot(showVortex ? band5_val : na, 'Band 5', color = color.new(phaseColor, 50), linewidth = math.max(1, vortexMode == 'Momentum Tunnel' ? 1 : 2))
p6 = plot(showVortex ? band6_val : na, 'Band 6', color = color.new(phaseColor, 70), linewidth = 1)
plot(showVortex and showVortexGlow ? band3_val : na, 'Glow', color = color.new(phaseColor, 88), linewidth = 10)
fill(p1, p2, color = showVortex ? trendUp ? bullPhaseColor : bearPhaseColor : na)
fill(p2, p3, color = showVortex ? trendUp ? color.new(bullColor, vortexTransparency - 10) : color.new(bearColor, vortexTransparency - 10) : na)
fill(p3, p4, color = showVortex ? trendUp ? color.new(bullColor, vortexTransparency + 2) : color.new(bearColor, vortexTransparency + 2) : na)
fill(p4, p5, color = showVortex ? trendUp ? color.new(bullColor, vortexTransparency - 10) : color.new(bearColor, vortexTransparency - 10) : na)
fill(p5, p6, color = showVortex ? trendUp ? bullPhaseColor : bearPhaseColor : na)
adxPlotColor = adx >= highADXThreshold ? bullColor : adx >= lowADXThreshold ? accentColor3 : bearColor
plot(adx, 'ADX', color = adxPlotColor, linewidth = 3)
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
// 📋 DASHBOARD
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
tablePos = switch panelPosition
    'Top Right' => position.top_right
    'Top Left' => position.top_left
    'Bottom Right' => position.bottom_right
    'Bottom Left' => position.bottom_left
    => position.top_right
var table hud = table.new(tablePos, 3, 20, bgcolor = color.new(bgColor, 5), border_width = 0, frame_width = 2, frame_color = color.new(frameColor, 40))
if showInfoPanel and barstate.islast
    sz = panelSize == 'Compact' ? size.tiny : panelSize == 'Extended' ? size.normal : size.small
    szS = panelSize == 'Extended' ? size.normal : size.small
    szH = panelSize == 'Extended' ? size.large : panelSize == 'Normal' ? size.normal : size.small
    table.cell(hud, 0, 0, 'ADX² CURVATURE', bgcolor = color.new(frameColor, 70), text_color = color.white, text_size = szH)
    table.cell(hud, 1, 0, 'SUITE', bgcolor = color.new(frameColor, 70), text_color = accentColor3, text_size = szH)
    table.cell(hud, 2, 0, '◈', bgcolor = color.new(frameColor, 70), text_color = accentColor1, text_size = szH)
    table.cell(hud, 0, 1, '━━━━━━━━━━━━', text_color = color.new(bullColor, 70), text_size = sz)
    table.cell(hud, 1, 1, 'MARKET', text_color = bullColor, text_size = sz)
    table.cell(hud, 2, 1, '━━━━━━━━━━━━', text_color = color.new(bullColor, 70), text_size = sz)
    adxStrength = adx >= 50 ? 'EXTREME' : adx >= 40 ? 'STRONG' : adx >= 25 ? 'MODERATE' : adx >= 20 ? 'WEAK' : 'NONE'
    adxStrColor = adx >= 40 ? bullColor : adx >= 25 ? accentColor3 : adx >= 20 ? neutralColor : bearColor
    table.cell(hud, 0, 2, 'ADX', text_color = neutralColor, text_size = sz)
    table.cell(hud, 1, 2, str.tostring(adx, '#.#'), text_color = phaseColor, text_size = szH)
    table.cell(hud, 2, 2, adxStrength, text_color = adxStrColor, text_size = sz)
    diWinner = plusDI > minusDI ? '▲ BULLS' : '▼ BEARS'
    diWinCol = plusDI > minusDI ? bullColor : bearColor
    diSpread = math.abs(plusDI - minusDI)
    table.cell(hud, 0, 3, 'BIAS', text_color = neutralColor, text_size = sz)
    table.cell(hud, 1, 3, diWinner, text_color = diWinCol, text_size = szS)
    table.cell(hud, 2, 3, str.tostring(diSpread, '#.#'), text_color = diWinCol, text_size = sz)
    table.cell(hud, 0, 4, '━━━━━━━━━━━━', text_color = color.new(accentColor2, 70), text_size = sz)
    table.cell(hud, 1, 4, 'MOMENTUM', text_color = accentColor2, text_size = sz)
    table.cell(hud, 2, 4, '━━━━━━━━━━━━', text_color = color.new(accentColor2, 70), text_size = sz)
    velLabel = adxVelocitySmooth > 1 ? '⇑ RISING' : adxVelocitySmooth < -1 ? '⇓ FALLING' : '⇔ FLAT'
    velCol = adxVelocitySmooth > 0 ? bullColor : bearColor
    table.cell(hud, 0, 5, 'VEL', text_color = neutralColor, text_size = sz)
    table.cell(hud, 1, 5, str.tostring(adxVelocitySmooth, '#.##'), text_color = velCol, text_size = szS)
    table.cell(hud, 2, 5, velLabel, text_color = velCol, text_size = sz)
    curvLabel = curvatureZScore > zThreshold ? '⚡ SPIKE' : curvatureZScore < -zThreshold ? '🔻 DROP' : '━ NORMAL'
    curvCol = curvatureZScore > ignitionThreshold ? ignitionBullColor : curvatureZScore < -exhaustionThreshold ? exhaustionBullColor : neutralColor
    table.cell(hud, 0, 6, 'CURV', text_color = neutralColor, text_size = sz)
    table.cell(hud, 1, 6, str.tostring(curvatureZScore, '#.##') + 'σ', text_color = curvCol, text_size = szS)
    table.cell(hud, 2, 6, curvLabel, text_color = curvCol, text_size = sz)
    rsiLabel = rsiOfADX > 70 ? 'OB' : rsiOfADX < 30 ? 'OS' : '━'
    rsiCol = rsiOfADX > 70 ? exhaustionBullColor : rsiOfADX < 30 ? ignitionBullColor : neutralColor
    table.cell(hud, 0, 7, 'RSI²', text_color = neutralColor, text_size = sz)
    table.cell(hud, 1, 7, str.tostring(rsiOfADX, '#.#'), text_color = rsiCol, text_size = szS)
    table.cell(hud, 2, 7, rsiLabel, text_color = rsiCol, text_size = sz)
    table.cell(hud, 0, 8, '━━━━━━━━━━━━', text_color = color.new(accentColor3, 70), text_size = sz)
    table.cell(hud, 1, 8, 'PHASE', text_color = accentColor3, text_size = sz)
    table.cell(hud, 2, 8, '━━━━━━━━━━━━', text_color = color.new(accentColor3, 70), text_size = sz)
    string phaseIcon = switch confirmedPhase
        PHASE_DORMANT => '💤'
        PHASE_IGNITION => '⚡'
        PHASE_ACCELERATION => '🚀'
        PHASE_MATURE => '🏔'
        PHASE_EXHAUSTION => '🔥'
        PHASE_DECLINE => '📉'
        => '━'
    table.cell(hud, 0, 9, phaseIcon, text_color = phaseColor, text_size = szH)
    table.cell(hud, 1, 9, confirmedPhase, text_color = phaseColor, text_size = szS)
    table.cell(hud, 2, 9, str.tostring(phaseCounter) + 'bars', text_color = frameColor, text_size = sz)
    sigIcon = trendIgniting ? '⚡' : trendExhausting ? '🔥' : trendAccelerating ? '🚀' : '○'
    sigText = trendIgniting ? 'IGNITION' : trendExhausting ? 'EXHAUSTION' : trendAccelerating ? 'ACCEL' : 'WAIT'
    sigCol = trendIgniting ? ignitionBullColor : trendExhausting ? exhaustionBullColor : trendAccelerating ? bullColor : neutralColor
    table.cell(hud, 0, 10, 'SIG', text_color = neutralColor, text_size = sz)
    table.cell(hud, 1, 10, sigText, text_color = sigCol, text_size = sz)
    table.cell(hud, 2, 10, str.tostring(signalStrength, '#') + '%', text_color = signalStrength > 50 ? accentColor3 : neutralColor, text_size = sz)
    table.cell(hud, 0, 11, '━━━━━━━━━━━━', text_color = color.new(frameColor, 70), text_size = sz)
    table.cell(hud, 1, 11, 'STATUS', text_color = frameColor, text_size = sz)
    table.cell(hud, 2, 11, '━━━━━━━━━━━━', text_color = color.new(frameColor, 70), text_size = sz)
    zoneTxt = inIgnZone ? '⚡ IGN' : inExhZone ? '🔥 EXH' : '○ NONE'
    zoneCol = inIgnZone ? ignitionBullColor : inExhZone ? exhaustionBullColor : neutralColor
    table.cell(hud, 0, 12, 'ZONE', text_color = neutralColor, text_size = sz)
    table.cell(hud, 1, 12, zoneTxt, text_color = zoneCol, text_size = sz)
    table.cell(hud, 2, 12, '', text_size = sz)
    divTxt = bullishDivergence ? '▲ BULL' : bearishDivergence ? '▼ BEAR' : '○ NONE'
    divCol = bullishDivergence ? divBullColor : bearishDivergence ? divBearColor : neutralColor
    table.cell(hud, 0, 13, 'DIV', text_color = neutralColor, text_size = sz)
    table.cell(hud, 1, 13, divTxt, text_color = divCol, text_size = sz)
    table.cell(hud, 2, 13, '', text_size = sz)
    activeLineCount = array.size(activeSignals)
    table.cell(hud, 0, 14, 'LINES', text_color = neutralColor, text_size = sz)
    table.cell(hud, 1, 14, str.tostring(activeLineCount) + '/20', text_color = frameColor, text_size = sz)
    table.cell(hud, 2, 14, '', text_size = sz)
    if optMode
        table.cell(hud, 0, 15, '━━━━━━━━━━━━', text_color = color.new(accentColor3, 70), text_size = sz)
        table.cell(hud, 1, 15, 'OPTIMIZER', text_color = accentColor3, text_size = sz)
        table.cell(hud, 2, 15, '━━━━━━━━━━━━', text_color = color.new(accentColor3, 70), text_size = sz)
        wrCol = btWinRate >= 55 ? bullColor : btWinRate >= 45 ? accentColor3 : bearColor
        table.cell(hud, 0, 16, 'WR', text_color = neutralColor, text_size = sz)
        table.cell(hud, 1, 16, str.tostring(btWinRate, '#.#') + '%', text_color = wrCol, text_size = szS)
        table.cell(hud, 2, 16, str.tostring(btTotalTrades), text_color = frameColor, text_size = sz)
        pfCol = btProfitFactor >= 1.5 ? bullColor : btProfitFactor >= 1.0 ? accentColor3 : bearColor
        table.cell(hud, 0, 17, 'PF', text_color = neutralColor, text_size = sz)
        table.cell(hud, 1, 17, str.tostring(btProfitFactor, '#.##'), text_color = pfCol, text_size = szS)
        table.cell(hud, 2, 17, robustText, text_color = robustCol, text_size = sz)
    table.cell(hud, 0, 18, '', text_size = sz)
    table.cell(hud, 1, 18, '⚡ Dskyz (DAFE) Trading Systems ⚡', text_color = color.new(frameColor, 50), text_size = sz)
    table.cell(hud, 2, 18, '', text_size = sz)
    // ═══════════════════════════════════════════════════════════════════════════════════════════════════════
    // 🔔 ALERTS
    // ═══════════════════════════════════════════════════════════════════════════════════════════════════════
alertcondition(trendIgniting and bullishBias, '⚡ Trend Ignition LONG', 'ADX² Suite: Trend IGNITING - Bullish Bias!')
alertcondition(trendIgniting and bearishBias, '⚡ Trend Ignition SHORT', 'ADX² Suite: Trend IGNITING - Bearish Bias!')
alertcondition(trendExhausting, '🔥 Trend Exhaustion', 'ADX² Suite: Trend EXHAUSTING!')
alertcondition(curvatureSpikeUp, '📈 Curvature Spike Up', 'ADX² Suite: Curvature spiking UP!')
alertcondition(curvatureSpikeDown, '📉 Curvature Spike Down', 'ADX² Suite: Curvature spiking DOWN!')
alertcondition(bullishDivergence, '🔄 Bullish Divergence', 'ADX² Suite: Bullish divergence!')
alertcondition(bearishDivergence, '🔄 Bearish Divergence', 'ADX² Suite: Bearish divergence!')
// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║                    ADX² CURVATURE SUITE - THEORY GUIDE                    ║
// ╚═══════════════════════════════════════════════════════════════════════════╝
//
// Traditional ADX analysis focuses on the magnitude of trend strength.
// The ADX² Suite introduces CURVATURE ANALYSIS - examining the rate of change
// (velocity) and acceleration of ADX to detect trend ignition BEFORE the crowd.
//
// Key Innovation: Just as price action analysis uses momentum and acceleration,
// we apply the same physics principles to ADX itself:
//
//   • ADX VALUE = Current trend strength (magnitude)
//   • VELOCITY = Rate of change in ADX (1st derivative)
//   • ACCELERATION = Change in velocity (2nd derivative / curvature)
//
// Why This Matters:
//   When ADX acceleration spikes WHILE ADX is still low, it signals trend
//   ignition - the market is transitioning from consolidation to trending.
//   This gives you early entry opportunities before ADX reaches traditional
//   "trend confirmation" levels (25+).
//
// ┌─────────────────────────────────────────────────────────────────────────┐
// │ 2. Z-SCORE NORMALIZATION                                                │
// └─────────────────────────────────────────────────────────────────────────┘
//
// Raw ADX acceleration values vary wildly across instruments and volatility
// regimes. Z-Score normalization solves this by converting values to standard
// deviations from the mean:
//
//   Z-Score = (Current Value - Mean) / Standard Deviation
//
// Benefits:
//   • Universal thresholds work across all instruments
//   • Adapts to changing volatility automatically
//   • 2.0σ spike is equally significant on NQ, ES, or crypto
//   • Eliminates need for instrument-specific calibration
//
// Interpretation:
//   +2.0σ = Extreme positive acceleration (ignition signal)
//   -2.0σ = Extreme negative acceleration (exhaustion signal)
//   0.0σ  = Average behavior (no significant change)
//
// ┌─────────────────────────────────────────────────────────────────────────┐
// │ 3. SIX-PHASE TREND LIFECYCLE                                            │
// └─────────────────────────────────────────────────────────────────────────┘
//
// The ADX² Suite models trends as a lifecycle with six distinct phases:
//
//   💤 DORMANT (ADX < 20, low velocity)
//      • No clear trend
//      • Choppy, range-bound price action
//      • Wait for ignition signal before entering
//
//   ⚡ IGNITION (ADX < 25, high acceleration)
//      • Trend beginning to form
//      • ADX accelerating rapidly from low levels
//      • HIGHEST PROBABILITY ENTRY ZONE
//      • Best risk/reward as stops are tight
//
//   🚀 ACCELERATION (ADX 20-40, positive velocity & acceleration)
//      • Trend gaining strength
//      • Momentum building
//      • Secondary entry opportunities
//      • Add to existing positions
//
//   🏔 MATURE (ADX > 40, velocity flat, acceleration negative)
//      • Strong established trend
//      • ADX high but no longer accelerating
//      • Caution: potential exhaustion ahead
//      • Consider taking partial profits
//
//   🔥 EXHAUSTION (ADX > 40, negative acceleration spike)
//      • Trend losing steam
//      • High probability of reversal or deep pullback
//      • EXIT SIGNAL for trend-following positions
//      • Potential counter-trend opportunity
//
//   📉 DECLINE (ADX falling, negative velocity)
//      • Trend weakening
//      • Return to range-bound conditions
//      • Avoid new entries
//      • Prepare for next dormant phase
//
// ┌─────────────────────────────────────────────────────────────────────────┐
// │ 4. KILL ZONES - HIGH PROBABILITY AREAS                                  │
// └─────────────────────────────────────────────────────────────────────────┘
//
// ⚡ IGNITION ZONE
//   Conditions: ADX < 20 + Positive Velocity + Acceleration > 0.75σ
//   
//   What It Means:
//   Price is transitioning from consolidation to trending. The market is
//   "waking up" from dormancy. This is where institutional orders begin
//   accumulating, creating the foundation for a new trend.
//
//   Trading Strategy:
//   • Prepare for entry on next confirmed signal
//   • Tight stops (market still consolidating)
//   • Position for trend-following opportunity
//   • High risk/reward ratio (3:1 or better)
//
// 🔥 EXHAUSTION ZONE  
//   Conditions: ADX > 32 + Negative Acceleration < -0.75σ
//   
//   What It Means:
//   Trend is overextended and losing momentum. While ADX remains high,
//   the rate of change is decelerating sharply - similar to a car
//   slamming on brakes while still moving fast.
//
//   Trading Strategy:
//   • Exit trend-following positions
//   • Take profits on swing trades
//   • Avoid new entries in trend direction
//   • Watch for reversal or deep retracement
//
// ┌─────────────────────────────────────────────────────────────────────────┐
// │ 5. SIGNAL HIERARCHY                                                     │
// └─────────────────────────────────────────────────────────────────────────┘
//
// PRIMARY SIGNALS (Triangles on chart)
//
//   ⚡ IGNITION SIGNALS
//      Strength: 30 points
//      Requirements: Phase transition to IGNITION + DI bias
//      Best For: Trend initiation entries
//      Timeframes: Most reliable on 5m, 1h, 4h
//
//   🚀 ACCELERATION SIGNALS  
//      Strength: 20 points
//      Requirements: ACCELERATION phase following IGNITION
//      Best For: Adding to positions, swing entries
//      Timeframes: All timeframes, especially 1h+
//
//   🔥 EXHAUSTION SIGNALS
//      Strength: 30 points
//      Requirements: Phase transition to EXHAUSTION + DI bias
//      Best For: Profit-taking, exits, counter-trend
//      Timeframes: Most significant on 1h, 4h
//
// SECONDARY SIGNALS (X markers on chart)
//
//   🔄 DIVERGENCE SIGNALS
//      Bullish: Price falling while ADX rising (trend strengthening into weakness)
//      Bearish: Price rising while ADX falling (trend weakening into strength)
//      Best For: Reversal anticipation, counter-trend trades
//      Timeframes: 5m for scalps, 1h+ for swings
//
// ┌─────────────────────────────────────────────────────────────────────────┐
// │ 6. QUANTUM VORTEX BANDS™                                                │
// └─────────────────────────────────────────────────────────────────────────┘
//
// The Vortex Bands provide dynamic support/resistance zones for ADX itself,
// adapting to both curvature (acceleration) and volatility.
//
// Band Modes:
//
//   TRIPLE LAYER (Default)
//   • Balanced bands with 3 zones above and below basis
//   • Width adapts to ADX volatility and curvature
//   • Best for: General purpose, all timeframes
//
//   FRACTAL CLOUD
//   • Wider outer bands, tighter inner core
//   • Emphasizes extreme movements
//   • Best for: High volatility instruments (crypto, NQ)
//
//   MOMENTUM TUNNEL
//   • Narrow, focused bands
//   • Thick inner bands for precision
//   • Best for: Lower timeframes (1m, 5m), scalping
//
//   PHASE SPECTRUM
//   • Balanced but slightly tighter than Triple Layer
//   • Color-coded by trend phase
//   • Best for: Visual phase identification, swing trading
//
// Interpretation:
//   • ADX touching upper bands = Strong momentum
//   • ADX in center zone = Normal behavior
//   • Band expansions = Increased volatility/acceleration
//   • Band contractions = Consolidation ahead
//
// ┌─────────────────────────────────────────────────────────────────────────┐
// │ 7. TIMEFRAME OPTIMIZATION                                               │
// └─────────────────────────────────────────────────────────────────────────┘
//
// 1-MINUTE TIMEFRAME (Scalping)
//   ADX Length: 10-14 (faster response)
//   Z-Score Lookback: 30-40 (shorter adaptation)
//   Signal Threshold: 2.0-2.5σ (more selective)
//   Min Bars Between: 5-8 (prevent over-trading)
//   Best Signals: Ignition + Acceleration
//   Notes: Expect more noise, focus on major ignitions only
//
// 5-MINUTE TIMEFRAME (Day Trading)
//   ADX Length: 14 (default)
//   Z-Score Lookback: 50 (balanced)
//   Signal Threshold: 1.5-2.0σ (moderate)
//   Min Bars Between: 8-10
//   Best Signals: All signal types
//   Notes: Sweet spot for intraday momentum trading
//
// 1-HOUR TIMEFRAME (Swing/Position)
//   ADX Length: 14-21 (smoother)
//   Z-Score Lookback: 50-75 (longer context)
//   Signal Threshold: 1.5σ (more signals)
//   Min Bars Between: 8-12
//   Best Signals: Ignition + Exhaustion + Divergence
//   Notes: More reliable, fewer false signals
//
// 4-HOUR TIMEFRAME (Position/Investment)
//   ADX Length: 14-21
//   Z-Score Lookback: 75-100 (long-term context)
//   Signal Threshold: 1.0-1.5σ (sensitive)
//   Min Bars Between: 3-5 (signals are rare)
//   Best Signals: Ignition + Exhaustion (major cycle changes)
//   Notes: Highly reliable, use for position sizing and bias
//
// ┌─────────────────────────────────────────────────────────────────────────┐
// │ 8. MULTI-TIMEFRAME CONFLUENCE                                           │
// └─────────────────────────────────────────────────────────────────────────┘
//
// Highest Probability Setups (3-Timeframe Alignment):
//
//   EXAMPLE: Trading NQ Futures
//   
//   4H Chart: IGNITION signal fired 3 bars ago (bullish bias established)
//   1H Chart: Currently in ACCELERATION phase (trend building)
//   5M Chart: Fresh IGNITION signal just fired (entry trigger)
//   
//   Action: Enter LONG on 5m IGNITION with:
//   • Stop: Below 5m signal line (tight)
//   • Target 1: 1H MATURE phase (TP1)
//   • Target 2: 4H EXHAUSTION signal (TP2)
//   • Risk/Reward: 5:1 or better
//
// Key Principles:
//   • Higher timeframe provides BIAS
//   • Lower timeframe provides ENTRY
//   • Exit on exhaustion signals OR higher TF phase change
//   • Never counter-trade higher timeframe ignition
//
// ┌─────────────────────────────────────────────────────────────────────────┐
// │ 9. RISK MANAGEMENT WITH SIGNAL LINES                                    │
// └─────────────────────────────────────────────────────────────────────────┘
//
// The Signal Line System provides automatic SL/TP management:
//
// ENTRY LINE (Colored)
//   • Marks exact signal trigger price
//   • Tracks win/loss with ✓/✗ markers
//   • Expires after max bars or price break
//
// STOP LOSS LINE (Red, dotted)
//   • Placed at Entry ± (ATR × SL Multiplier)
//   • Default: 1.5 ATR (balanced)
//   • Scalping: 0.75-1.0 ATR (tight)
//   • Swing: 2.0-3.0 ATR (wider)
//
// TAKE PROFIT LINES (Green, varying opacity)
//   TP1: 1.0 ATR (quick profit, 50% off)
//   TP2: 2.0 ATR (primary target, 30% off)
//   TP3: 3.0 ATR (runner, let it ride)
//
// Position Management:
//   1. Enter full position at signal
//   2. Move stop to breakeven at TP1
//   3. Take 50% profit at TP1
//   4. Take 30% profit at TP2
//   5. Trail stop for final 20% until TP3 or exhaustion signal
//
// ┌─────────────────────────────────────────────────────────────────────────┐
// │ 10. ADVANCED: OPTIMIZER ENGINE                                          │
// └─────────────────────────────────────────────────────────────────────────┘
//
// The Optimizer Engine backtests signals across the visible chart:
//
// Metrics Tracked:
//   • Win Rate (target: 50%+)
//   • Profit Factor (target: 1.5+)
//   • Total Trades (minimum: 20 for statistical relevance)
//   • Expectancy (average profit per trade)
//
// Stability Scoring:
//   ROBUST (80+ points): Settings optimized, ready for live trading
//   STABLE (60-79): Good performance, minor tweaking may help
//   FRAGILE (40-59): Inconsistent, needs parameter adjustment
//   OVERFIT (<40): Poor performance, major changes required
//
// How To Use:
//   1. Enable Optimizer in settings
//   2. Load historical data (500+ bars minimum)
//   3. Adjust TP/SL multipliers
//   4. Check dashboard for stability rating
//   5. Aim for ROBUST or STABLE before live trading
//
// Warning: Optimizer uses simplified entry/exit logic. Always verify
// signals manually before risking real capital.
