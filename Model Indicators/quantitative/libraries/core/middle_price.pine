library("", "v1.0.0", overlay=false)


int p = input.int(14, "Period", minval=1)

export midprice(int period) =>
    float hi = ta.highest(high, period)
    float lo = ta.lowest(low, period)
    (hi + lo) * 0.5


result = midprice(p)

