library("", "v1.0.0", overlay=false)


//@function Calculates the typical price as the average of high, low, and close prices
//@param h High price series
//@param l Low price series
//@param c Close price series
//@returns float The typical price (high + low + close) * 0.333333
//@optimized Uses multiplication instead of division for performance
export hlc3(series float h, series float l, series float c) =>
    (h + l + c) * 0.333333


// ---------- Main loop ----------

// Calculation
result = hlc3(high, low, close)

// Plot
// plot(result, "HLC3", color=color.yellow, linewidth=2)  // Disabled in library

