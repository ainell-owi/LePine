library("", "v1.0.0", overlay=false)


//@function Calculates the average of open, high, and low prices
//@param o Open price series
//@param h High price series
//@param l Low price series
//@returns float The average value (open + high + low) * 0.333333
//@optimized Uses multiplication instead of division for performance
export ohl3(series float o, series float h, series float l) =>
    (o + h + l) * 0.333333


// ---------- Main loop ----------

// Calculation
result = ohl3(open, high, low)

// Plot
// plot(result, "OHL3", color=color.yellow, linewidth=2)  // Disabled in library

