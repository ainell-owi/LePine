//@version=6
indicator("Reverse Stochastic %J", shorttitle="Rev%J", overlay=true)

// Input parameters
k_length = input.int(14, title="%K Length", minval=1)
d_length = input.int(3, title="%D Length", minval=1)
target_j = input.float(80.0, title="Target %J Value", minval=-100, maxval=200)
show_levels = input.bool(true, title="Show Price Levels")
show_current_j = input.bool(true, title="Show Current %J")

// Current Stochastic calculations for reference
current_k = ta.stoch(close, high, low, k_length)
current_d = ta.sma(current_k, d_length)
current_j = 3 * current_k - 2 * current_d

// Get the highest high and lowest low for the period
hh = ta.highest(high, k_length)
ll = ta.lowest(low, k_length)

// Calculate what %D will be if we use current %K values (excluding current bar)
// We need the %D that would result from the previous bars plus our target %K
k_sum_prev = math.sum(ta.stoch(close[1], high[1], low[1], k_length), d_length - 1)

// Reverse calculation: Given target %J, what close price do we need?
// %J = 3*%K - 2*%D
// We need to solve for the close price that gives us the target %J

// Function to calculate required close price for target %J
calc_required_close(target_j_val, hh_val, ll_val, prev_d) =>
    // If range is zero, return current close
    if hh_val == ll_val
        close
    else
        // %J = 3*%K - 2*%D
        // %K = (close - ll) / (hh - ll) * 100
        // We need to estimate what %D will be with our new %K
        // For simplification, we'll use current %D as approximation
        // target_j = 3 * ((required_close - ll) / (hh - ll) * 100) - 2 * current_d
        // Solving for required_close:
        required_k = (target_j_val + 2 * current_d) / 3
        required_close = ll_val + (required_k / 100) * (hh_val - ll_val)
        required_close

// Calculate required close price
required_close = calc_required_close(target_j, hh, ll, current_d)

// Calculate what %J would be at different price levels
j_at_high = 3 * 100 - 2 * current_d  // If close = high
j_at_low = 3 * 0 - 2 * current_d     // If close = low

// Plotting
plot(show_current_j ? current_j : na, title="Current %J", color=color.blue, linewidth=2)
hline(target_j, title="Target %J", color=color.yellow, linestyle=hline.style_dashed)
hline(80, title="Overbought", color=color.red, linestyle=hline.style_dotted)
hline(20, title="Oversold", color=color.green, linestyle=hline.style_dotted)

// Price level plots on main chart
plot(show_levels ? required_close : na, title="Required Close", color=color.orange, linewidth=2, style=plot.style_circles)
plot(show_levels ? hh : na, title="Period High", color=color.red, linewidth=1, style=plot.style_stepline)
plot(show_levels ? ll : na, title="Period Low", color=color.green, linewidth=1, style=plot.style_stepline)

// Background coloring based on feasibility
bgcolor(required_close > hh ? color.new(color.red, 90) : 
        required_close < ll ? color.new(color.green, 90) : 
        color.new(color.yellow, 95))

// Table showing the calculations
if barstate.islast and show_levels
    var table info_table = table.new(position.top_right, 2, 8, bgcolor=color.white, border_width=1)
    table.cell(info_table, 0, 0, "Metric", text_color=color.black, bgcolor=color.gray)
    table.cell(info_table, 1, 0, "Value", text_color=color.black, bgcolor=color.gray)
    table.cell(info_table, 0, 1, "Current %J", text_color=color.black)
    table.cell(info_table, 1, 1, str.tostring(current_j, "#.##"), text_color=color.black)
    table.cell(info_table, 0, 2, "Target %J", text_color=color.black)
    table.cell(info_table, 1, 2, str.tostring(target_j, "#.##"), text_color=color.black)
    table.cell(info_table, 0, 3, "Required Close", text_color=color.black)
    table.cell(info_table, 1, 3, str.tostring(required_close, "#.####"), text_color=color.black)
    table.cell(info_table, 0, 4, "Current Close", text_color=color.black)
    table.cell(info_table, 1, 4, str.tostring(close, "#.####"), text_color=color.black)
    table.cell(info_table, 0, 5, "Period High", text_color=color.black)
    table.cell(info_table, 1, 5, str.tostring(hh, "#.####"), text_color=color.black)
    table.cell(info_table, 0, 6, "Period Low", text_color=color.black)
    table.cell(info_table, 1, 6, str.tostring(ll, "#.####"), text_color=color.black)
    table.cell(info_table, 0, 7, "Feasible?", text_color=color.black)
    feasible = required_close >= ll and required_close <= hh
    table.cell(info_table, 1, 7, feasible ? "Yes" : "No", 
               text_color=feasible ? color.green : color.red)

// Alert conditions
alert_condition = math.abs(close - required_close) < (hh - ll) * 0.01  // Within 1% of range
alertcondition(alert_condition, title="Close to Target", message="Price is near required level for target %J")