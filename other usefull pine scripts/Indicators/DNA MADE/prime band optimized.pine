//@version=6
indicator("HMA sweete", overlay=true, max_bars_back=1000)

// ====== HMA SECTION ======
// HMA Inputs
src_hull = input(close, 'HMA Source', group='HMA Settings')

// MA1 Settings
ma1_mode = input.string('Hma', 'MA1 Type', ['Hma', 'Thma', 'Ehma','zhm', 'zrm', 'zehma','ema','sma','hma','rma','sma_native','ema_native'], group='MA1 Settings')
length_hull1 = input.float(25.0, 'MA1 Length', group='MA1 Settings')
lengthMult1 = input.float(1.0, 'MA1 Length Multiplier', 0.1, 50, 0.1, group='MA1 Settings')
hist = input.int(6, 'History Bars', group='MA1 Settings')

// MA2 Settings
ma2_enabled = input.bool(false, 'Enable MA2?', group='MA2 Settings')
ma2_mode = input.string('Thma', 'MA2 Type', ['Hma', 'Thma', 'Ehma','zhm', 'zrm', 'zehma','ema','sma','hma','rma','sma_native','ema_native'], group='MA2 Settings')
length_hull2 = input.float(27.5, 'MA2 Length', group='MA2 Settings')
lengthMult2 = input.float(1.0, 'MA2 Length Multiplier', 0.1, 50, 0.1, group='MA2 Settings')
hist2 = input.int(2, 'History Bars', group='MA1 Settings')

// MA3 Settings
ma3_enabled = input.bool(false, 'Enable MA3?', group='MA3 Settings')
ma3_mode = input.string('Ehma', 'MA3 Type', ['Hma', 'Thma', 'Ehma','zhm', 'zrm', 'zehma','ema','sma','hma','rma','sma_native','ema_native'], group='MA3 Settings')
length_hull3 = input.float(55, 'MA3 Length', minval=1, group='MA3 Settings')
lengthMult3 = input.float(1.0, 'MA3 Length Multiplier', 0.1, 50, 0.1, group='MA3 Settings')
hist3 = input.int(2, 'History Bars', group='MA3 Settings')


// ====== COLOR SPECTRUM SETTINGS ======
// Fill Transparency
fill_transparency = input.int(25, 'Fill Transparency', 0, 100,20, group='Visual Settings')






// ====== HMA FUNCTIONS ======
HMA(_src, _length) =>
    ta.wma(2 * ta.wma(_src, _length / 2) - ta.wma(_src, _length), math.round(math.sqrt(_length)))

EHMA(_src, _length) =>
    ta.ema(2 * ta.ema(_src, _length / 2) - ta.ema(_src, _length), math.round(math.sqrt(_length)))

THMA(_src, _length) =>
    ta.wma(ta.wma(_src, _length / 3) * 3 - ta.wma(_src, _length / 2) - ta.wma(_src, _length), _length)



hma = ta.hma(close, 30)
rma = ta.rma(close,21)

sma = ta.sma(close,21)
ema = ta.ema(close,21)

hmalen = input.int(21,'zhma')
rmalen = input.int(21,'zrma')

ehmalen = input.int(21 ,'zwma' )
thmalen = input.int(21,'vwma')
smalen = input.int(21, 'zema') 
emalen = input.int(21, 'zsma')
f_zhm(_src, _length) =>
    var _l = (_length + 1) / 2
    _srcL = _src + nz(ta.mom(_src, _l))
    _zhma = ta.hma(close,hmalen)



f_zrm(_src, _length) =>
    var _l = (_length + 1) / 2
    _srcL = _src + nz(ta.mom(_src, _l))
    _zrma = ta.rma(_srcL,rmalen )




f_em(_src, _length) =>
    var _l = (_length + 1) / 2
    _srcL = _src + nz(ta.mom(_src, _l))
    _zema = ta.ema(_srcL,smalen)
f_sm(_src, _length) =>
    var _l = (_length + 1) / 2
    _srcL = _src + nz(ta.mom(_src, _l))
    _zsma = ta.sma(_srcL, emalen)





f_zehma(_src, _length) =>
    var _l = (_length + 1) / 2
    _srcL = _src + nz(ta.mom(_src, _l))
    _zehma = EHMA(close, hmalen)



// ====== HMA FUNCTIONS ======

// Clean Switch Functions for each HMA
get_ma1(src, len) =>
    switch ma1_mode
        'Hma' => HMA(src, len)
        'Thma' => THMA(src, len / 2)
        'Ehma' => EHMA(src, len)
        'zhm'  => f_zhm(src,len)
        'zrm' =>  f_zrm(src,len)
        'ema' =>  f_em(src,len)
        'sma' => f_sm(src,len)
        'zehma' => f_zehma(src,len)
        'hma' => ta.hma(src, int(len))
        'rma' => ta.rma(src, int(len))
        'sma_native' => ta.sma(src, int(len))
        'ema_native' => ta.ema(src, int(len))
 

get_ma2(src, len) =>
    switch ma2_mode
        'Hma' => HMA(src, len)
        'Thma' => THMA(src, len / 2)
        'Ehma' => EHMA(src, len)
        'zhm'  => f_zhm(src,len)
        'zrm' =>  f_zrm(src,len)
        'ema' =>  f_em(src,len)
        'sma' => f_sm(src,len)
        'zehma' => f_zehma(src,len)
        'hma' => ta.hma(src, int(len))
        'rma' => ta.rma(src, int(len))
        'sma_native' => ta.sma(src, int(len))
        'ema_native' => ta.ema(src, int(len))

get_ma3(src, len) =>
    switch ma3_mode
        'Hma' => HMA(src, len)
        'Thma' => THMA(src, len / 2)
        'Ehma' => EHMA(src, len)
        'zhm'  => f_zhm(src,len)
        'zrm' =>  f_zrm(src,len)
        'ema' =>  f_em(src,len)
        'sma' => f_sm(src,len)
        'zehma' => f_zehma(src,len)
        'hma' => ta.hma(src, int(len))
        'rma' => ta.rma(src, int(len))
        'sma_native' => ta.sma(src, int(len))
        'ema_native' => ta.ema(src, int(len))

// ====== COLOR CALCULATION FUNCTIONS ======
// Slope-based color function
f_slopeColor(bool direction, int previ) =>
    up = ta.rising(close,previ)
    down =ta.falling(close,previ)
     
    bool slope = direction ? up : down
    


// ====== CALCULATIONS ======
// Calculate HMAs using clean switch logic
ma1 = get_ma1(src_hull, int(length_hull1 * lengthMult1))
ma2 = ma2_enabled ? get_ma2(src_hull, int(length_hull2 * lengthMult2)) : na
ma3 = ma3_enabled ? get_ma3(src_hull, int(length_hull3 * lengthMult3)) : na
n=input.int(1,'n')
// Current and historical values
MHULL1 = ma1[0]
MHULL2 = ma2[0]
MHULL3 = ma3[0]
SHULL1 = MHULL1[hist]
SHULL2 = MHULL2[hist2]
SHULL3 = MHULL3[hist3]
// ====== COLOR PALETTE SYSTEM ======
// Core Gradient Colors (Used in MA1 by default)
colorUpBottom = color.new(#09a3b8, 0) // Dark Teal - Upslope Bottom
colorUpTop = color.new(#a517e7, 0) // Bright Magenta - Upslope Top
colorDownTop = color.new(#360079, 0) // Purple - Downslope Top

// ====== DOWNSLOPE COLOR PALETTE ======
// Pink/Magenta Range (Bearish/Negative Slope)
c1 = input.color(#ff79ff, 'Light Pink - Downslope Bottom', inline='down1', group='Downslope Colors')
c2 = input.color(#e600ff, 'Bright Magenta - Downslope Mid', inline='down1', group='Downslope Colors')
c3 = input.color(color.rgb(157, 20, 136), 'Deep Magenta - Downslope High', inline='down2', group='Downslope Colors')
c7 = input.color(color.rgb(126, 55, 207), 'Purple Magenta - Downslope Alt', inline='down2', group='Downslope Colors')

// Mauve/Purple Range
c5 = input.color(color.rgb(141, 71, 109), 'Mauve - Downslope Low', inline='down3', group='Downslope Colors')
c6 = input.color(color.rgb(155, 74, 192), 'Purple - Downslope Mid', inline='down3', group='Downslope Colors')

// Dark Red Range (Strong Bearish)
c4 = input.color(color.rgb(111, 0, 17), 'Dark Red - Downslope Extreme', inline='down4', group='Downslope Colors')

// ====== UPSLOPE COLOR PALETTE ======
// Blue Range (Bullish/Positive Slope)
c8 = input.color(#7eadf3, 'Light Blue - Upslope Low', inline='up1', group='Upslope Colors')
c9 = input.color(color.rgb(81, 200, 255), 'Sky Blue - Upslope Mid', inline='up1', group='Upslope Colors')
ca = input.color(#009dff, 'Bright Blue - Upslope High', inline='up2', group='Upslope Colors')
cf = input.color(color.rgb(31, 148, 178), 'Deep Cyan - Upslope Alt', inline='up2', group='Upslope Colors')

// Green Range (Strong Bullish)
cb = input.color(#237400, 'Dark Green - Upslope Low', inline='up3', group='Upslope Colors')
cc = input.color(#6bbc49, 'Mid Green - Upslope Mid', inline='up3', group='Upslope Colors')
cd = input.color(#1ba071, 'Teal Green - Upslope High', inline='up4', group='Upslope Colors')
ce = input.color(color.rgb(42, 255, 198), 'Bright Cyan - Upslope Extreme', inline='up4', group='Upslope Colors')

// ====== ADDITIONAL COLOR THEMES ======
// Ocean Theme (Blue-Green Harmony)
ocean_up_bottom = input.color(#0d4f5c, 'Ocean - Up Bottom', inline='ocean', group='Theme: Ocean')
ocean_up_top = input.color(#00d4ff, 'Ocean - Up Top', inline='ocean', group='Theme: Ocean')
ocean_down_top = input.color(#003d52, 'Ocean - Down Top', inline='ocean2', group='Theme: Ocean')
ocean_down_bottom = input.color(#66b3cc, 'Ocean - Down Bottom', inline='ocean2', group='Theme: Ocean')

// Fire Theme (Red-Orange Harmony)
fire_up_bottom = input.color(#5c0d0d, 'Fire - Up Bottom', inline='fire', group='Theme: Fire')
fire_up_top = input.color(#ff4500, 'Fire - Up Top', inline='fire', group='Theme: Fire')
fire_down_top = input.color(#330000, 'Fire - Down Top', inline='fire2', group='Theme: Fire')
fire_down_bottom = input.color(#ff6347, 'Fire - Down Bottom', inline='fire2', group='Theme: Fire')

// Forest Theme (Green Harmony)
forest_up_bottom = input.color(#1a3d1a, 'Forest - Up Bottom', inline='forest', group='Theme: Forest')
forest_up_top = input.color(#7fff00, 'Forest - Up Top', inline='forest', group='Theme: Forest')
forest_down_top = input.color(#0d2b0d, 'Forest - Down Top', inline='forest2', group='Theme: Forest')
forest_down_bottom = input.color(#90ee90, 'Forest - Down Bottom', inline='forest2', group='Theme: Forest')

// Purple Haze Theme (Purple-Violet Harmony)
haze_up_bottom = input.color(#2d0a4e, 'Haze - Up Bottom', inline='haze', group='Theme: Purple Haze')
haze_up_top = input.color(#da70d6, 'Haze - Up Top', inline='haze', group='Theme: Purple Haze')
haze_down_top = input.color(#1a0033, 'Haze - Down Top', inline='haze2', group='Theme: Purple Haze')
haze_down_bottom = input.color(#dda0dd, 'Haze - Down Bottom', inline='haze2', group='Theme: Purple Haze')
// Calculate dynamic slope range
slope = MHULL1 - MHULL1[n] // Slope calculation
rangeLen = 50 // Period to check historical slope range
maxSlope = ta.highest(math.abs(slope), rangeLen)
minSlope = 0.0 // Slope can be normalized around 0 for up/down logic
normalizedSlope = math.sign(slope) * (math.abs(slope) / maxSlope) // Range will be approximately -1 to 1 dynamically


///MHULL1
ss = ta.crossover(MHULL1,SHULL1)
alertcondition(ss,'ma1 cross ovr1','ma1 long')
// Get colors based on individual slopes
hullColor1 = slope >= 0 ? color.from_gradient(normalizedSlope, minSlope, 1.0, colorUpBottom, colorUpTop) : color.from_gradient(normalizedSlope, -1.0, minSlope, colorDownTop,c1 )
hullColor11 = slope >= 0 ? color.from_gradient(normalizedSlope, minSlope, 1.0, colorDownTop, colorUpBottom) : color.from_gradient(normalizedSlope, -1.0, minSlope, c1, colorDownTop)


// ====== PLOTS ======
// MA1 Plots (always declared)
Fi1_a = plot(MHULL1, title='MHULL1', color=#000000, linewidth=4)
Fi1_b = plot(MHULL1, title='MHULL1', color=#000000, linewidth=4)

Fi1 = plot(MHULL1, title='MHULL1', color=  MHULL1[1] >SHULL1  ? #0080ff : color.rgb(255, 106, 0), linewidth=1)
Fi2 = plot(SHULL1, title='SHULL1', color= MHULL1[1] >SHULL1  ? #0080ff : color.rgb(255, 106, 0) ,linewidth=1)
fill(plot1 = Fi1,plot2 = Fi2, top_value = MHULL1, bottom_value = SHULL1, top_color = MHULL1[1]> SHULL1 ? hullColor1 : na ,bottom_color =hullColor11, title='MA1 Band')


n2 = input.int(5, 'ma2 slope lookback')
// Calculate dynamic slope range for MA2
slope2 = MHULL2 - MHULL2[n2] // Slope calculation
rangeLen2 = 50 // Period to check historical slope range
maxSlope2 = ta.highest(math.abs(slope2), rangeLen2)
minSlope2 = 0.0 // Slope can be normalized around 0 for up/down logic
normalizedSlope2 = math.sign(slope2) * (math.abs(slope2) / maxSlope2) // Range will be approximately -1 to 1 dynamically
// MA2 colors following MA1 pattern
hullColor2 = slope2 >= 0 ? color.from_gradient(normalizedSlope2, minSlope2, 1.0, colorUpBottom, colorUpTop) : color.from_gradient(normalizedSlope2, -1.0, minSlope2, colorDownTop, c2)
hullColor22 = slope2 >= 0 ? color.from_gradient(normalizedSlope2, minSlope2, 1.0, colorDownTop, colorUpBottom) : color.from_gradient(normalizedSlope2, -1.0, minSlope2, c2, colorDownTop)

//hullColor22 = f_slopeColor(MHULL2, SHULL2)
// hullColor3 = f_slopeColor(MHULL3, SHULL3)

n3 = input.int(5, 'ma3 slope lookback')
// Calculate dynamic slope range for MA3
slope3 = MHULL3 - MHULL3[n3] // Slope calculation
rangeLen3 = 50 // Period to check historical slope range
maxSlope3 = ta.highest(math.abs(slope3), rangeLen3)
minSlope3 = 0.0 // Slope can be normalized around 0 for up/down logic
normalizedSlope3 = math.sign(slope3) * (math.abs(slope3) / maxSlope3) // Range will be approximately -1 to 1 dynamically
// MA3 colors following MA1 pattern
hullColor3 = slope3 >= 0 ? color.from_gradient(normalizedSlope3, minSlope3, 1.0, colorUpBottom, colorUpTop) : color.from_gradient(normalizedSlope3, -1.0, minSlope3, colorDownTop, c3)
hullColor33 = slope3 >= 0 ? color.from_gradient(normalizedSlope3, minSlope3, 1.0, colorDownTop, colorUpBottom) : color.from_gradient(normalizedSlope3, -1.0, minSlope3, c3, colorDownTop)

// MA2 Plots
Fi3b = plot(ma2_enabled ? MHULL2 : na, title='MHULL2', color=#000000, linewidth=4)
Fi4b = plot(ma2_enabled ? SHULL2 : na, title='SHULL2', color=#000000, linewidth=4)
Fi3 = plot(ma2_enabled ? MHULL2 : na, title='MHULL2', color= MHULL2[1] > SHULL2 ? #0080ff : #ff6a00, linewidth=1)
Fi4 = plot(ma2_enabled ? SHULL2 : na, title='SHULL2', color= MHULL2[1] > SHULL2 ? #0080ff : #ff6a00, linewidth=1)
fill(plot1 = Fi3, plot2 = Fi4, top_value = MHULL2, bottom_value = SHULL2, top_color = MHULL2[1] > SHULL2 ? hullColor2 : na, bottom_color = hullColor22, title='MA2 Band')

// MA3 Plots
Fi5b = plot(ma3_enabled ? MHULL3 : na, title='MHULL3', color=#000000, linewidth=4)
Fi6b = plot(ma3_enabled ? SHULL3 : na, title='SHULL3', color=#000000, linewidth=4)
Fi5 = plot(ma3_enabled ? MHULL3 : na, title='MHULL3', color= MHULL3[1] > SHULL3 ? #0080ff : #ff6a00, linewidth=1)
Fi6 = plot(ma3_enabled ? SHULL3 : na, title='SHULL3', color= MHULL3[1] > SHULL3 ? #0080ff : #ff6a00, linewidth=1)
fill(plot1 = Fi5, plot2 = Fi6, top_value = MHULL3, bottom_value = SHULL3, top_color = MHULL3[1] > SHULL3 ? hullColor3 : na, bottom_color = hullColor33, title='MA3 Band')
