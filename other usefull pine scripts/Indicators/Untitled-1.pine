//@version=6
//@dnatradez

//import Gentleman-Goat/TradingToolsLibrary/1 as ttl
import TradingView/ta/10

indicator('hmCCI', 'HMACCI', true)

_src = input.source(close)
_length = input.int(28, 'len')

// ====== HMA SECTION ======
src_hull1 = input.source(close, 'HMA Source', group = 'HMA Settings')

// MA1 Settings
ma1_mode = input.string('Hma', 'MA1 Type', ['Hma', 'Thma', 'Ehma', 'hema'], group = 'MA1 Settings')
length_hull1 = input.float(29.0, 'MA1 Length', group = 'MA1 Settings')
lengthMult1 = input.float(1.0, 'MA1 Length Multiplier', 0.01, 50, 0.01, group = 'MA1 Settings')
cur1 = input.int(0, 'MA1 Current Bar Offset', group = 'MA1 Settings')
hist1 = input.int(1, 'MA1 History Bars', group = 'MA1 Settings')
MA1up1 = input.color(#009dff, 'MA1 Up Top', inline = 'ma1up', group = 'MA1 Settings')
MA1up2 = input.color(color.rgb(0, 255, 234), 'MA1 Up Bottom', inline = 'ma1up', group = 'MA1 Settings')
MA1dwn1 = input.color(#ffffff, 'MA1 Down Top', inline = 'ma1dwn', group = 'MA1 Settings')
MA1dwn2 = input.color(#960000, 'MA1 Down Bottom', inline = 'ma1dwn', group = 'MA1 Settings')
neutral_color1 = input.color(color.rgb(180, 157, 255), 'MA1 Neutral', group = 'MA1 Settings')
ma1_line_up = input.color(color.new(#f66669, 0), 'MA1 Line Up Color', group = 'MA1 Settings')
ma1_line_down = input.color(color.new(#6966f6, 0), 'MA1 Line Down Color', group = 'MA1 Settings')

// MA2 Settings
ma2_enabled = input.bool(false, 'Enable MA2?', group = 'MA2 Settings')
ma2_mode = input.string('Thma', 'MA2 Type', ['Hma', 'Thma', 'Ehma'], group = 'MA2 Settings')
length_hull2 = input.float(55, 'MA2 Length', group = 'MA2 Settings')
lengthMult2 = input.float(1.0, 'MA2 Length Multiplier', 0.01, 50, 0.01, group = 'MA2 Settings')
cur2 = input.int(0, 'MA2 Current Bar Offset', group = 'MA2 Settings')
hist2 = input.int(1, 'MA2 History Bars', group = 'MA2 Settings')
MA2up1 = input.color(#38617a, 'MA2 Up Top', inline = 'ma2up', group = 'MA2 Settings')
MA2up2 = input.color(#814681, 'MA2 Up Bottom', inline = 'ma2up', group = 'MA2 Settings')
MA2dwn1 = input.color(#4892b7, 'MA2 Down Top', inline = 'ma2dwn', group = 'MA2 Settings')
MA2dwn2 = input.color(#288db8, 'MA2 Down Bottom', inline = 'ma2dwn', group = 'MA2 Settings')
neutral_color2 = input.color(color.rgb(180, 157, 255), 'MA2 Neutral', group = 'MA2 Settings')
ma2_line_up = input.color(color.new(#69f666, 0), 'MA2 Line Up Color', group = 'MA2 Settings')
ma2_line_down = input.color(color.new(#f6d966, 0), 'MA2 Line Down Color', group = 'MA2 Settings')

// MA3 Settings
ma3_enabled = input.bool(false, 'Enable MA3?', group = 'MA3 Settings')
ma3_mode = input.string('Ehma', 'MA3 Type', ['Hma', 'Thma', 'Ehma'], group = 'MA3 Settings')
length_hull3 = input.float(55, 'MA3 Length', minval = 1, group = 'MA3 Settings')
lengthMult3 = input.float(4.0, 'MA3 Length Multiplier', 0.01, 50, 0.01, group = 'MA3 Settings')
cur3 = input.int(0, 'MA3 Current Bar Offset', group = 'MA3 Settings')
hist3 = input.int(2, 'MA3 History Bars', group = 'MA3 Settings')
MA3up1 = input.color(#38617a, 'MA3 Up Top', inline = 'ma3up', group = 'MA3 Settings')
MA3up2 = input.color(#814681, 'MA3 Up Bottom', inline = 'ma3up', group = 'MA3 Settings')
MA3dwn1 = input.color(#4892b7, 'MA3 Down Top', inline = 'ma3dwn', group = 'MA3 Settings')
MA3dwn2 = input.color(#288db8, 'MA3 Down Bottom', inline = 'ma3dwn', group = 'MA3 Settings')
neutral_color3 = input.color(color.rgb(180, 157, 255), 'MA3 Neutral', group = 'MA3 Settings')
ma3_line_up = input.color(color.new(#ff9966, 0), 'MA3 Line Up Color', group = 'MA3 Settings')
ma3_line_down = input.color(color.new(#66ffcc, 0), 'MA3 Line Down Color', group = 'MA3 Settings')

//@optimized Uses three-stage exponential warmup compensators for O(1) complexity
supersmoother(_drc,_length =>
    pi = 3.14159
    y = math.exp(-math.sqrt(2) * pi / len)
    c = -y * y
    b = 2.0 * y * math.cos(math.sqrt(2) * pi / len)
    a = 1 - b - c
    z = 0.0
    iff_1 = bar_index == 2 ? b * nz(z[1]) + c * nz(z[2]) : a * ((x + nz(x[1])) / 2) + b * nz(z[1]) + c * nz(z[2])
    iff_2 = bar_index == 1 ? b * nz(z[1]) : iff_1
    z := bar_index == 0 ? 0.0 : iff_2
    z
hema(series float src, simple int N) =>
    float alphaSlow = 3.0 / (2.0 * N - 1.0)
    float lambdaSlow = -math.log(1.0 - alphaSlow)
    float ratio = math.log(2.0) / (1.0 + math.log(2.0))
    float alphaFast = 1.0 - math.exp(-lambdaSlow / ratio)
    float alphaSmooth = 2.0 / (math.sqrt(N) / 2.0 + 1.0)
    float betaSlow = 1.0 - alphaSlow
    float betaFast = 1.0 - alphaFast
    float betaSmooth = 1.0 - alphaSmooth
    float chkSlow = nz(alphaSlow, 1.0)
    float chkFast = nz(alphaFast, 1.0)
    float chkSmth = nz(alphaSmooth, 1.0)
    float alphaMin = math.min(chkSlow, chkFast, chkSmth, 0.000001)
    var bool warmup = true
    var float decaySlow = 1.0
    var float decayFast = 1.0
    var float decaySmooth = 1.0
    var float emaSlowRaw = 0.0
    var float emaFastRaw = 0.0
    var float emaSmoothRaw = 0.0
    float emaSlow = na
    float emaFast = na
    float hemaVal = na
    emaSlowRaw := alphaSlow * (src - emaSlowRaw) + emaSlowRaw
    emaFastRaw := alphaFast * (src - emaFastRaw) + emaFastRaw
    if warmup
        decaySlow *= betaSlow
        decayFast *= betaFast
        decaySmooth *= betaSmooth
        emaSlow := (1.0 / (1.0 - decaySlow)) * emaSlowRaw
        emaFast := (1.0 / (1.0 - decayFast)) * emaFastRaw
        float deLag = emaFast / (1.0 - ratio) - ratio * emaSlow / (1.0 - ratio)
        emaSmoothRaw := alphaSmooth * (deLag - emaSmoothRaw) + emaSmoothRaw
        hemaVal := (1.0 / (1.0 - decaySmooth)) * emaSmoothRaw
        warmup := decaySlow > 1e-10
    else
        emaSlow := emaSlowRaw
        emaFast := emaFastRaw
        float deLag = emaFast / (1.0 - ratio) - ratio * emaSlow / (1.0 - ratio)
        emaSmoothRaw := alphaSmooth * (deLag - emaSmoothRaw) + emaSmoothRaw
        hemaVal := emaSmoothRaw
    hemaVal

// ---------- Main loop ----------

// Calculation
hema = hema(_src, _length)
// ====== HMA FUNCTIONS ======
HMA(_src, _length) =>
    ta.wma(2 * ta.wma(_src, _length / 2) - ta.wma(_src, _length), math.round(math.sqrt(_length)))

EHMA(_src, _length) =>
    ta.ema(2 * ta.ema(_src, _length / 2) - ta.ema(_src, _length), math.round(math.sqrt(_length)))

THMA(_src, _length) =>
    ta.wma(ta.wma(_src, _length / 3) * 3 - ta.wma(_src, _length / 2) - ta.wma(_src, _length), _length)

RMAHMA(_src, _length) =>
    ta.rma(ta.rma(_src, _length / 3) * 3 - ta.rma(_src, _length / 2) - ta.rma(_src, _length), _length)

// Clean Switch Functions for each HMA
get_ma1(src_hull1, len) =>
    switch ma1_mode
        'Hma' => HMA(_src, len)
        'Thma' => THMA(_src, len / 2)
        'Ehma' => EHMA(_src, len)
        'hema' => hema(_src, len/2)

get_ma2(src, len) =>
    switch ma2_mode
        'Hma' => HMA(src, len)
        'Thma' => THMA(src, len / 2)
        'Ehma' => EHMA(src, len)

get_ma3(src, len) =>
    switch ma3_mode
        'Hma' => HMA(src, len)
        'Thma' => THMA(src, len / 2)
        'Ehma' => EHMA(src, len)

// ====== CALCULATIONS ======
ma1 = get_ma1(src_hull1, int(length_hull1 * lengthMult1))
ma2 = ma2_enabled ? get_ma2(_src, int(length_hull2 * lengthMult2)) : na
ma3 = ma3_enabled ? get_ma3(_src, int(length_hull3 * lengthMult3)) : na

// Current and historical values
fh1 = ma1[cur1]
sh1 = fh1[hist1]

fh2 = ma2[cur2]
sh2 = fh2[hist2]

fh3 = ma3[cur3]
sh3 = fh3[hist3]

// Double gradient calculations for MA1
grad1_up_top = color.from_gradient(fh1, low, high, MA1up1, MA1up2)
grad1_up_bot = color.from_gradient(sh1, low, high, MA1up1, MA1up2)
fill1_up = color.from_gradient(fh1, sh1, fh1, grad1_up_top, grad1_up_bot)

grad1_dwn_top = color.from_gradient(fh1, low, high, MA1dwn1, MA1dwn2)
grad1_dwn_bot = color.from_gradient(sh1, low, high, MA1dwn1, MA1dwn2)
fill1_dwn = color.from_gradient(fh1, sh1, fh1, grad1_dwn_top, grad1_dwn_bot)

grady1 = fh1 > fh1[1] ? fill1_up : fill1_dwn
ol1 = fh1 > fh1[1] ? ma1_line_up : ma1_line_down

// Double gradient calculations for MA2
grad2_up_top = color.from_gradient(fh2, low, high, MA2up1, MA2up2)
grad2_up_bot = color.from_gradient(sh2, low, high, MA2up1, MA2up2)
fill2_up = color.from_gradient(fh2, sh2, fh2, grad2_up_top, grad2_up_bot)

grad2_dwn_top = color.from_gradient(fh2, low, high, MA2dwn1, MA2dwn2)
grad2_dwn_bot = color.from_gradient(sh2, low, high, MA2dwn1, MA2dwn2)
fill2_dwn = color.from_gradient(fh2, sh2, fh2, grad2_dwn_top, grad2_dwn_bot)

grady2 = fh2 > fh2[1] ? fill2_up : fill2_dwn
ol2 = fh2 > fh2[1] ? ma2_line_up : ma2_line_down

// Double gradient calculations for MA3
grad3_up_top = color.from_gradient(fh3, low, high, MA3up1, MA3up2)
grad3_up_bot = color.from_gradient(sh3, low, high, MA3up1, MA3up2)
fill3_up = color.from_gradient(fh3, sh3, fh3, grad3_up_top, grad3_up_bot)

grad3_dwn_top = color.from_gradient(fh3, low, high, MA3dwn1, MA3dwn2)
grad3_dwn_bot = color.from_gradient(sh3, low, high, MA3dwn1, MA3dwn2)
fill3_dwn = color.from_gradient(fh3, sh3, fh3, grad3_dwn_top, grad3_dwn_bot)

grady3 = fh3 > fh3[1] ? fill3_up : fill3_dwn
ol3 = fh3 > fh3[1] ? ma3_line_up : ma3_line_down

// ====== PLOTS ======
// MA1 Plots
Fi1 = plot(fh1, title = 'MHULL1', color = ol1, linewidth = 2, force_overlay = true)
Fi2 = plot(sh1, title = 'SHULL1', color = ol1, linewidth = 2, force_overlay = true)
fill(Fi1, Fi2, title = 'MA1 Band', color = color.new(grady1, 0))

// MA2 Plots
Fi3 = plot(ma2_enabled ? fh2 : na, title = 'MHULL2', color = ol2, linewidth = 2, force_overlay = true)
Fi4 = plot(ma2_enabled ? sh2 : na, title = 'SHULL2', color = ol2, linewidth = 2, force_overlay = true)
fill(Fi3, Fi4, title = 'MA2 Band', color = color.new(grady2, 0))

// MA3 Plots
Fi5 = plot(ma3_enabled ? fh3 : na, title = 'MHULL3', color = ol3, linewidth = 2, force_overlay = true)
Fi6 = plot(ma3_enabled ? sh3 : na, title = 'SHULL3', color = ol3, linewidth = 2, force_overlay = true)
//fill(Fi3, Fi6, title = 'MA3 Band', color = color.new(grady3, 0))
