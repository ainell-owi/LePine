//@version=6

strategy("Skeleton Key v2 Enhanced - Threshold B/C/D/E Logic", "SKE-v2+", overlay = true, pyramiding = 5)
//
// SKELETON KEY v2 ENHANCED - Hyper-Configurable Strategy Builder
//
// ENHANCEMENTS OVER TAKE 2:
// - Threshold E added (5 total threshold signals)
// - Source offset % added to all thresholds (like External Sources)
// - Enhanced operators: rising, falling, crosses_above, crosses_below
// - Cleaner function-based signal generation
//
// Signal Types: Threshold A/B/C/D/E, External Sources A/B/C/D
// Logic Groups: AND-A, AND-B, OR (3 independent tracks)
// Tuners: Historical Bar Index, Bars Valid, Profit Filter, Offsets
//
// ============================================================================

// ============================================================================
// STRATEGY SETTINGS
// ============================================================================

stratDirection = input.string("Long", "Strategy Direction",
    options = ["Long", "Short"],
    group = "Strategy Settings",
    tooltip = "Trade direction: Long only or Short only")

// ============================================================================
// HELPER FUNCTIONS
// ============================================================================

// Enhanced threshold comparison function with dynamic operators
f_threshold_compare_enhanced(float src, float src_prev, string op, float val) =>
    switch op
        "<"  => src < val
        ">"  => src > val
        "<=" => src <= val
        ">=" => src >= val
        "==" => src == val
        "rising" => src > src_prev
        "falling" => src < src_prev
        "crosses_above" => src_prev <= val and src > val
        "crosses_below" => src_prev >= val and src < val
        => false

// External sources comparison function (includes crossover/crossunder)
f_external_compare(float src1, string op, float src2, float src1_prev, float src2_prev) =>
    switch op
        "<"  => src1 < src2
        ">"  => src1 > src2
        "<=" => src1 <= src2
        ">=" => src1 >= src2
        "==" => src1 == src2
        "crossover"  => src1_prev < src2_prev and src1 > src2
        "crossunder" => src1_prev > src2_prev and src1 < src2
        => false

// Profit filter function
f_profit_filter(string filter) =>
    if filter == "ANY"
        true
    else if filter == "PROFIT"
        strategy.position_size != 0 ? strategy.openprofit > 0 : true
    else if filter == "LOSS"
        strategy.position_size != 0 ? strategy.openprofit < 0 : true
    else
        true

// ============================================================================
// THRESHOLD SIGNAL A
// ============================================================================
// Structure: {source} {operator} {value}
// Example: RSI >= 70
// Operators: <, >, <=, >=, ==, rising, falling, crosses_above, crosses_below

thresh_enabled_A = input.bool(true, "Enable Threshold Signal?",
    group = "═══ THRESHOLD A ═══",
    tooltip = "Enable/disable this signal")

thresh_source_A = input.source(close, "",
    inline = 'threshA',
    group = "═══ THRESHOLD A ═══",
    tooltip = "Data source to evaluate")

thresh_operator_A = input.string(">=", "",
    inline = 'threshA',
    options = ["<", ">", "<=", ">=", "==", "rising", "falling", "crosses_above", "crosses_below"],
    group = "═══ THRESHOLD A ═══",
    tooltip = "Comparison operator")

thresh_value_A = input.float(0.0, "",
    inline = 'threshA',
    group = "═══ THRESHOLD A ═══",
    tooltip = "Value to compare against")

thresh_offset_A = input.float(0.0, "Source Offset %",
    minval = -100, maxval = 100, step = 0.1,
    group = "═══ THRESHOLD A ═══",
    tooltip = "Percentage offset applied to source before comparison")

thresh_hist_bar_A = input.int(0, "Historical Bar Index",
    minval = 0,
    group = "═══ THRESHOLD A ═══",
    tooltip = "Use value from N bars ago (0 = current bar)")

thresh_bars_valid_A = input.int(0, "Bars Signal is Valid",
    minval = 0,
    group = "═══ THRESHOLD A ═══",
    tooltip = "Signal stays active for N bars after becoming true")

thresh_profit_filter_A = input.string("ANY", "Profit Filter",
    options = ["ANY", "PROFIT", "LOSS"],
    group = "═══ THRESHOLD A ═══",
    tooltip = "Signal only active if profit filter matches")

thresh_entry_A = input.bool(true, "Entry",
    inline = 'threshA_action',
    group = "═══ THRESHOLD A ═══",
    tooltip = "Use this signal for entries")

thresh_exit_A = input.bool(false, "Exit",
    inline = 'threshA_action',
    group = "═══ THRESHOLD A ═══",
    tooltip = "Use this signal for exits")

thresh_entry_logic_A = input.string("AND-A", "Entry Logical Group",
