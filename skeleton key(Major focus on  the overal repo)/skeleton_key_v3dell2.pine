//@version=6

strategy("Skeleton Key v3 - Threshold + External Sources", "SKE-v3", overlay = true, pyramiding = 5)
//
// SKELETON KEY v3 - Hyper-Configurable Strategy Builder
// Signal Types: Threshold A/B/C/D, External Sources A/B/C/D
// Logic Groups: AND-A, AND-B, OR (3 independent tracks)
// Tuners: Historical Bar Index, Bars Valid, Profit Filter, Offsets
//  
// ============================================================================

// SKELETON KEY EXTERNAL - STRATEGY BUILDER

// ============================================================================

// This strategy replicates the core signal logic from DSKyZInvestments'

// Skeleton Key External indicator, using TradingView's alert dialog logic

// structure but triggering strategy orders instead of alerts.

//

// SIGNAL TYPES IN THIS VERSION:

// - Threshold: {source} {operator} {value}

// - External Sources: {source1} {operator} {source2}

//

// LOGICAL GROUPING SYSTEM:

// - AND-A: All AND-A signals must be TRUE together to trigger

// - AND-B: All AND-B signals must be TRUE together to trigger

// - OR: Each OR signal triggers independently

// These are 3 SEPARATE TRACKS - they don't interact with each other

// ============================================================================

 

// ============================================================================

// STRATEGY SETTINGS

// ============================================================================

 

stratDirection = input.string("Long", "Strategy Direction",

    options = ["Long", "Short"],

    group = "Strategy Settings",

    tooltip = "Trade direction: Long only or Short only")

 

// ============================================================================

// THRESHOLD SIGNAL

// ============================================================================

// Structure: {source} {operator} {value}

// Example: Close < 25

// Operators: <, >, <=, >=, ==

 

thresh_enabled = input.bool(true, "Enable Threshold Signal?",
    group = "═══ THRESHOLD SIGNAL A═══",
    tooltip = "Enable/disable this signal")

 

thresh_source = input.source(close, "",
    inline = 'threshA',
    group = "═══ THRESHOLD SIGNAL A═══",
    tooltip = "Data source to evaluate")

 

thresh_operator = input.string(">=", "",
    inline = 'threshA',
    options = ["<", ">", "<=", ">=", "=="],
    group = "═══ THRESHOLD SIGNAL A═══",
    tooltip = "Comparison operator")

 

thresh_value = input.float(0.0, "",
    inline = 'threshA',
    group = "═══ THRESHOLD SIGNAL A═══",
    tooltip = "Value to compare against")

 

thresh_hist_bar = input.int(0, "Historical Bar Index",
    minval = 0,
    group = "═══ THRESHOLD SIGNAL A═══",
    tooltip = "Use value from N bars ago (0 = current bar)")

 

thresh_bars_valid = input.int(0, "Bars Signal is Valid",
    minval = 0,
    group = "═══ THRESHOLD SIGNAL A═══",
    tooltip = "Signal stays active for N bars after becoming true. Allows AND conditions to sync up.")



thresh_profit_filter = input.string("ANY", "Profit Filter",
    options = ["ANY", "PROFIT", "LOSS"],
    group = "═══ THRESHOLD SIGNAL A═══",
    tooltip = "Signal only active if profit filter matches current position state")

 

thresh_entry = input.bool(true, "Entry",
    inline = 'threshA',
    group = "═══ THRESHOLD SIGNAL A═══",
    tooltip = "Use this signal for entries")

 

thresh_exit = input.bool(false, "Exit",
    inline = 'threshA',
    group = "═══ THRESHOLD SIGNAL A═══",
    tooltip = "Use this signal for exits")

 

thresh_entry_logic = input.string("AND-A", "Entry Logical Group",
    options = ["AND-A", "AND-B", "OR"],
    group = "═══ THRESHOLD SIGNAL A═══",
    tooltip = "Which entry logic group this signal belongs to")

thresh_exit_logic = input.string("OR", "Exit Logical Group",
    options = ["AND-A", "AND-B", "OR"],
    group = "═══ THRESHOLD SIGNAL A═══",
    tooltip = "Which exit logic group this signal belongs to")
