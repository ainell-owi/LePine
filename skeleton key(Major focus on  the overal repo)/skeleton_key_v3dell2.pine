// ============================================================================
// HELPER FUNCTIONS
// ============================================================================

// Threshold comparison function

f_threshold_compare(float src, string op, float val) =>
    switch op
        "<"  => src < val
        ">"  => src > val
        "<=" => src <= val
        ">=" => src >= val
        "==" => src == val
        => false

 

// External sources comparison function (includes crossover/crossunder)

f_external_compare(float src1, string op, float src2, float src1_prev, float src2_prev) =>
    switch op
        "<"  => src1 < src2
        ">"  => src1 > src2
        "<=" => src1 <= src2
        ">=" => src1 >= src2
        "==" => src1 == src2
        "crossover"  => src1_prev < src2_prev and src1 > src2
        "crossunder" => src1_prev > src2_prev and src1 < src2
        => false

// Profit filter function

f_profit_filter(string filter) =>
    if filter == "ANY"
        true
    else if filter == "PROFIT"
        strategy.position_size != 0 ? strategy.openprofit > 0 : true
    else if filter == "LOSS"
        strategy.position_size != 0 ? strategy.openprofit < 0 : true
    else
        true

 

// Bars valid tracking function
// Returns true if signal was true within last N bars
f_bars_valid(bool signal_raw, int bars_valid) =>
    if bars_valid == 0
        signal_raw

    else
        var int bars_since_true = 999999
        if signal_raw
            bars_since_true := 0
        else
            bars_since_true := bars_since_true + 1
        bars_since_true <= bars_valid

// ============================================================================
// THRESHOLD SIGNAL CALCULATION
// ============================================================================

// Get source value with historical bar offset
thresh_src_val = thresh_source[thresh_hist_bar]
 
// Raw condition check
thresh_raw = thresh_enabled and f_threshold_compare(thresh_src_val, thresh_operator, thresh_value)

 

// Apply bars valid
var int thresh_bars_since_true = 999999

if thresh_raw
    thresh_bars_since_true := 0

else
    thresh_bars_since_true := thresh_bars_since_true + 1
thresh_signal_valid = thresh_enabled and thresh_bars_since_true <= thresh_bars_valid

 

// Apply profit filter
thresh_signal_entry = thresh_signal_valid and thresh_entry and f_profit_filter(thresh_profit_filter)
thresh_signal_exit = thresh_signal_valid and thresh_exit and f_profit_filter(thresh_profit_filter)

// ═══════════════════════════════════════════════════════════════════════════
// THRESHOLD B SIGNAL CALCULATION
// ═══════════════════════════════════════════════════════════════════════════

thresh_src_val_B = thresh_source_B[thresh_hist_bar_B]
thresh_raw_B = thresh_enabled_B and f_threshold_compare(thresh_src_val_B, thresh_operator_B, thresh_value_B)

var int thresh_bars_since_true_B = 999999
if thresh_raw_B
    thresh_bars_since_true_B := 0
else
    thresh_bars_since_true_B := thresh_bars_since_true_B + 1
thresh_signal_valid_B = thresh_enabled_B and thresh_bars_since_true_B <= thresh_bars_valid_B

thresh_signal_entry_B = thresh_signal_valid_B and thresh_entry_B and f_profit_filter(thresh_profit_filter_B)
thresh_signal_exit_B = thresh_signal_valid_B and thresh_exit_B and f_profit_filter(thresh_profit_filter_B)

// ═══════════════════════════════════════════════════════════════════════════
// THRESHOLD C SIGNAL CALCULATION
// ═══════════════════════════════════════════════════════════════════════════

thresh_src_val_C = thresh_source_C[thresh_hist_bar_C]
thresh_raw_C = thresh_enabled_C and f_threshold_compare(thresh_src_val_C, thresh_operator_C, thresh_value_C)

var int thresh_bars_since_true_C = 999999
if thresh_raw_C
    thresh_bars_since_true_C := 0
else
    thresh_bars_since_true_C := thresh_bars_since_true_C + 1
thresh_signal_valid_C = thresh_enabled_C and thresh_bars_since_true_C <= thresh_bars_valid_C

thresh_signal_entry_C = thresh_signal_valid_C and thresh_entry_C and f_profit_filter(thresh_profit_filter_C)
thresh_signal_exit_C = thresh_signal_valid_C and thresh_exit_C and f_profit_filter(thresh_profit_filter_C)

// ═══════════════════════════════════════════════════════════════════════════
// THRESHOLD D SIGNAL CALCULATION
// ═══════════════════════════════════════════════════════════════════════════

thresh_src_val_D = thresh_source_D[thresh_hist_bar_D]
thresh_raw_D = thresh_enabled_D and f_threshold_compare(thresh_src_val_D, thresh_operator_D, thresh_value_D)

var int thresh_bars_since_true_D = 999999
if thresh_raw_D
    thresh_bars_since_true_D := 0
else
    thresh_bars_since_true_D := thresh_bars_since_true_D + 1
thresh_signal_valid_D = thresh_enabled_D and thresh_bars_since_true_D <= thresh_bars_valid_D

thresh_signal_entry_D = thresh_signal_valid_D and thresh_entry_D and f_profit_filter(thresh_profit_filter_D)
thresh_signal_exit_D = thresh_signal_valid_D and thresh_exit_D and f_profit_filter(thresh_profit_filter_D)

// ============================================================================
// EXTERNAL SOURCES SIGNAL CALCULATION
// ============================================================================

 

// Get source values with offsets and historical bar indices
ext_src1_val = ext_source1[ext_hist_bar1] * (1 + ext_offset1 / 100)
ext_src2_val = ext_source2[ext_hist_bar2] * (1 + ext_offset2 / 100)

 

// Get previous values for crossover/crossunder detection
ext_src1_prev = ext_source1[ext_hist_bar1 + 1] * (1 + ext_offset1 / 100)
ext_src2_prev = ext_source2[ext_hist_bar2 + 1] * (1 + ext_offset2 / 100)

 

// Raw condition check
ext_raw = ext_enabled and f_external_compare(ext_src1_val, ext_operator, ext_src2_val, ext_src1_prev, ext_src2_prev)

// Apply bars valid

var int ext_bars_since_true = 999999

if ext_raw
    ext_bars_since_true := 0

else
    ext_bars_since_true := ext_bars_since_true + 1
ext_signal_valid = ext_enabled and ext_bars_since_true <= ext_bars_valid

 

// Apply profit filter
ext_signal_entry = ext_signal_valid and ext_entry and f_profit_filter(ext_profit_filter)
ext_signal_exit = ext_signal_valid and ext_exit and f_profit_filter(ext_profit_filter)

// ═══════════════════════════════════════════════════════════════════════════
// EXTERNAL SOURCES B SIGNAL CALCULATION
// ═══════════════════════════════════════════════════════════════════════════

ext_src1_val_B = ext_source1_B[ext_hist_bar1_B] * (1 + ext_offset1_B / 100)
ext_src2_val_B = ext_source2_B[ext_hist_bar2_B] * (1 + ext_offset2_B / 100)
ext_src1_prev_B = ext_source1_B[ext_hist_bar1_B + 1] * (1 + ext_offset1_B / 100)
ext_src2_prev_B = ext_source2_B[ext_hist_bar2_B + 1] * (1 + ext_offset2_B / 100)

ext_raw_B = ext_enabled_B and f_external_compare(ext_src1_val_B, ext_operator_B, ext_src2_val_B, ext_src1_prev_B, ext_src2_prev_B)

var int ext_bars_since_true_B = 999999
if ext_raw_B
    ext_bars_since_true_B := 0
else
    ext_bars_since_true_B := ext_bars_since_true_B + 1
ext_signal_valid_B = ext_enabled_B and ext_bars_since_true_B <= ext_bars_valid_B

ext_signal_entry_B = ext_signal_valid_B and ext_entry_B and f_profit_filter(ext_profit_filter_B)
ext_signal_exit_B = ext_signal_valid_B and ext_exit_B and f_profit_filter(ext_profit_filter_B)

// ═══════════════════════════════════════════════════════════════════════════
// EXTERNAL SOURCES C SIGNAL CALCULATION
// ═══════════════════════════════════════════════════════════════════════════

ext_src1_val_C = ext_source1_C[ext_hist_bar1_C] * (1 + ext_offset1_C / 100)
ext_src2_val_C = ext_source2_C[ext_hist_bar2_C] * (1 + ext_offset2_C / 100)
ext_src1_prev_C = ext_source1_C[ext_hist_bar1_C + 1] * (1 + ext_offset1_C / 100)
ext_src2_prev_C = ext_source2_C[ext_hist_bar2_C + 1] * (1 + ext_offset2_C / 100)

ext_raw_C = ext_enabled_C and f_external_compare(ext_src1_val_C, ext_operator_C, ext_src2_val_C, ext_src1_prev_C, ext_src2_prev_C)

var int ext_bars_since_true_C = 999999
if ext_raw_C
    ext_bars_since_true_C := 0
else
    ext_bars_since_true_C := ext_bars_since_true_C + 1
ext_signal_valid_C = ext_enabled_C and ext_bars_since_true_C <= ext_bars_valid_C

ext_signal_entry_C = ext_signal_valid_C and ext_entry_C and f_profit_filter(ext_profit_filter_C)
ext_signal_exit_C = ext_signal_valid_C and ext_exit_C and f_profit_filter(ext_profit_filter_C)

// ═══════════════════════════════════════════════════════════════════════════
// EXTERNAL SOURCES D SIGNAL CALCULATION
// ═══════════════════════════════════════════════════════════════════════════

ext_src1_val_D = ext_source1_D[ext_hist_bar1_D] * (1 + ext_offset1_D / 100)
ext_src2_val_D = ext_source2_D[ext_hist_bar2_D] * (1 + ext_offset2_D / 100)
ext_src1_prev_D = ext_source1_D[ext_hist_bar1_D + 1] * (1 + ext_offset1_D / 100)
ext_src2_prev_D = ext_source2_D[ext_hist_bar2_D + 1] * (1 + ext_offset2_D / 100)

ext_raw_D = ext_enabled_D and f_external_compare(ext_src1_val_D, ext_operator_D, ext_src2_val_D, ext_src1_prev_D, ext_src2_prev_D)

var int ext_bars_since_true_D = 999999
if ext_raw_D
    ext_bars_since_true_D := 0
else
    ext_bars_since_true_D := ext_bars_since_true_D + 1
ext_signal_valid_D = ext_enabled_D and ext_bars_since_true_D <= ext_bars_valid_D

ext_signal_entry_D = ext_signal_valid_D and ext_entry_D and f_profit_filter(ext_profit_filter_D)
ext_signal_exit_D = ext_signal_valid_D and ext_exit_D and f_profit_filter(ext_profit_filter_D)

// ============================================================================
// ENTRY LOGIC GROUPS (3 Independent Tracks)
// ============================================================================

// AND-A: All AND-A entry signals must be TRUE → triggers entry
// AND-B: All AND-B entry signals must be TRUE → triggers entry
// OR:    Any OR entry signal TRUE → triggers entry independently

 

// Count how many signals are assigned to each entry group
entry_andA_count = (thresh_entry and thresh_entry_logic == "AND-A" ? 1 : 0) +
                   (thresh_entry_B and thresh_entry_logic_B == "AND-A" ? 1 : 0) +
                   (thresh_entry_C and thresh_entry_logic_C == "AND-A" ? 1 : 0) +
                   (thresh_entry_D and thresh_entry_logic_D == "AND-A" ? 1 : 0) +
                   (ext_entry and ext_entry_logic == "AND-A" ? 1 : 0) +
                   (ext_entry_B and ext_entry_logic_B == "AND-A" ? 1 : 0) +
                   (ext_entry_C and ext_entry_logic_C == "AND-A" ? 1 : 0) +
                   (ext_entry_D and ext_entry_logic_D == "AND-A" ? 1 : 0)

entry_andB_count = (thresh_entry and thresh_entry_logic == "AND-B" ? 1 : 0) +
                   (thresh_entry_B and thresh_entry_logic_B == "AND-B" ? 1 : 0) +
                   (thresh_entry_C and thresh_entry_logic_C == "AND-B" ? 1 : 0) +
                   (thresh_entry_D and thresh_entry_logic_D == "AND-B" ? 1 : 0) +
                   (ext_entry and ext_entry_logic == "AND-B" ? 1 : 0) +
                   (ext_entry_B and ext_entry_logic_B == "AND-B" ? 1 : 0) +
                   (ext_entry_C and ext_entry_logic_C == "AND-B" ? 1 : 0) +
                   (ext_entry_D and ext_entry_logic_D == "AND-B" ? 1 : 0)

// Count how many signals are TRUE in each entry group
entry_andA_true = (thresh_signal_entry and thresh_entry_logic == "AND-A" ? 1 : 0) +
                  (thresh_signal_entry_B and thresh_entry_logic_B == "AND-A" ? 1 : 0) +
                  (thresh_signal_entry_C and thresh_entry_logic_C == "AND-A" ? 1 : 0) +
                  (thresh_signal_entry_D and thresh_entry_logic_D == "AND-A" ? 1 : 0) +
                  (ext_signal_entry and ext_entry_logic == "AND-A" ? 1 : 0) +
                  (ext_signal_entry_B and ext_entry_logic_B == "AND-A" ? 1 : 0) +
                  (ext_signal_entry_C and ext_entry_logic_C == "AND-A" ? 1 : 0) +
                  (ext_signal_entry_D and ext_entry_logic_D == "AND-A" ? 1 : 0)

entry_andB_true = (thresh_signal_entry and thresh_entry_logic == "AND-B" ? 1 : 0) +
                  (thresh_signal_entry_B and thresh_entry_logic_B == "AND-B" ? 1 : 0) +
                  (thresh_signal_entry_C and thresh_entry_logic_C == "AND-B" ? 1 : 0) +
                  (thresh_signal_entry_D and thresh_entry_logic_D == "AND-B" ? 1 : 0) +
                  (ext_signal_entry and ext_entry_logic == "AND-B" ? 1 : 0) +
                  (ext_signal_entry_B and ext_entry_logic_B == "AND-B" ? 1 : 0) +
                  (ext_signal_entry_C and ext_entry_logic_C == "AND-B" ? 1 : 0) +
                  (ext_signal_entry_D and ext_entry_logic_D == "AND-B" ? 1 : 0)

// AND-A Entry: All AND-A signals must be true (and at least 1 must exist)
entry_andA_trigger = entry_andA_count > 0 and entry_andA_true == entry_andA_count

// AND-B Entry: All AND-B signals must be true (and at least 1 must exist)
entry_andB_trigger = entry_andB_count > 0 and entry_andB_true == entry_andB_count

// OR Entry: Any OR signal can trigger independently
entry_or_trigger = (thresh_signal_entry and thresh_entry_logic == "OR") or
                   (thresh_signal_entry_B and thresh_entry_logic_B == "OR") or
                   (thresh_signal_entry_C and thresh_entry_logic_C == "OR") or
                   (thresh_signal_entry_D and thresh_entry_logic_D == "OR") or
                   (ext_signal_entry and ext_entry_logic == "OR") or
                   (ext_signal_entry_B and ext_entry_logic_B == "OR") or
                   (ext_signal_entry_C and ext_entry_logic_C == "OR") or
                   (ext_signal_entry_D and ext_entry_logic_D == "OR")

 

// Final entry signal (any of the 3 tracks can trigger)

entry_signal = entry_andA_trigger or entry_andB_trigger or entry_or_trigger

 

// ============================================================================

// EXIT LOGIC GROUPS (3 Independent Tracks)

// ============================================================================

// Same structure as entry but for exits

 

// Count how many signals are assigned to each exit group
exit_andA_count = (thresh_exit and thresh_exit_logic == "AND-A" ? 1 : 0) +
                  (thresh_exit_B and thresh_exit_logic_B == "AND-A" ? 1 : 0) +
                  (thresh_exit_C and thresh_exit_logic_C == "AND-A" ? 1 : 0) +
                  (thresh_exit_D and thresh_exit_logic_D == "AND-A" ? 1 : 0) +
                  (ext_exit and ext_exit_logic == "AND-A" ? 1 : 0) +
                  (ext_exit_B and ext_exit_logic_B == "AND-A" ? 1 : 0) +
                  (ext_exit_C and ext_exit_logic_C == "AND-A" ? 1 : 0) +
                  (ext_exit_D and ext_exit_logic_D == "AND-A" ? 1 : 0)

exit_andB_count = (thresh_exit and thresh_exit_logic == "AND-B" ? 1 : 0) +
                  (thresh_exit_B and thresh_exit_logic_B == "AND-B" ? 1 : 0) +
                  (thresh_exit_C and thresh_exit_logic_C == "AND-B" ? 1 : 0) +
                  (thresh_exit_D and thresh_exit_logic_D == "AND-B" ? 1 : 0) +
                  (ext_exit and ext_exit_logic == "AND-B" ? 1 : 0) +
                  (ext_exit_B and ext_exit_logic_B == "AND-B" ? 1 : 0) +
                  (ext_exit_C and ext_exit_logic_C == "AND-B" ? 1 : 0) +
                  (ext_exit_D and ext_exit_logic_D == "AND-B" ? 1 : 0)

// Count how many signals are TRUE in each exit group
exit_andA_true = (thresh_signal_exit and thresh_exit_logic == "AND-A" ? 1 : 0) +
                 (thresh_signal_exit_B and thresh_exit_logic_B == "AND-A" ? 1 : 0) +
                 (thresh_signal_exit_C and thresh_exit_logic_C == "AND-A" ? 1 : 0) +
                 (thresh_signal_exit_D and thresh_exit_logic_D == "AND-A" ? 1 : 0) +
                 (ext_signal_exit and ext_exit_logic == "AND-A" ? 1 : 0) +
                 (ext_signal_exit_B and ext_exit_logic_B == "AND-A" ? 1 : 0) +
                 (ext_signal_exit_C and ext_exit_logic_C == "AND-A" ? 1 : 0) +
                 (ext_signal_exit_D and ext_exit_logic_D == "AND-A" ? 1 : 0)

exit_andB_true = (thresh_signal_exit and thresh_exit_logic == "AND-B" ? 1 : 0) +
                 (thresh_signal_exit_B and thresh_exit_logic_B == "AND-B" ? 1 : 0) +
                 (thresh_signal_exit_C and thresh_exit_logic_C == "AND-B" ? 1 : 0) +
                 (thresh_signal_exit_D and thresh_exit_logic_D == "AND-B" ? 1 : 0) +
                 (ext_signal_exit and ext_exit_logic == "AND-B" ? 1 : 0) +
                 (ext_signal_exit_B and ext_exit_logic_B == "AND-B" ? 1 : 0) +
                 (ext_signal_exit_C and ext_exit_logic_C == "AND-B" ? 1 : 0) +
                 (ext_signal_exit_D and ext_exit_logic_D == "AND-B" ? 1 : 0)

// AND-A Exit: All AND-A exit signals must be true
exit_andA_trigger = exit_andA_count > 0 and exit_andA_true == exit_andA_count

// AND-B Exit: All AND-B exit signals must be true
exit_andB_trigger = exit_andB_count > 0 and exit_andB_true == exit_andB_count

// OR Exit: Any OR exit signal triggers independently
exit_or_trigger = (thresh_signal_exit and thresh_exit_logic == "OR") or
                  (thresh_signal_exit_B and thresh_exit_logic_B == "OR") or
                  (thresh_signal_exit_C and thresh_exit_logic_C == "OR") or
                  (thresh_signal_exit_D and thresh_exit_logic_D == "OR") or
                  (ext_signal_exit and ext_exit_logic == "OR") or
                  (ext_signal_exit_B and ext_exit_logic_B == "OR") or
                  (ext_signal_exit_C and ext_exit_logic_C == "OR") or
                  (ext_signal_exit_D and ext_exit_logic_D == "OR")

 

// Final exit signal (any of the 3 tracks can trigger)
exit_signal = exit_andA_trigger or exit_andB_trigger or exit_or_trigger

 

// ============================================================================

// STRATEGY EXECUTION

// ============================================================================

 

// Direction filters

is_long = stratDirection == "Long"
is_short = stratDirection == "Short"

 

// Long entries/exits

if entry_signal and is_long
    strategy.entry("Long", strategy.long)

 

if exit_signal and is_long and strategy.position_size > 0
    strategy.close("Long")

 

// Short entries/exits

if entry_signal and is_short
    strategy.entry("Short", strategy.short)

if exit_signal and is_short and strategy.position_size < 0
    strategy.close("Short")

 

// ============================================================================

// VISUAL FEEDBACK

// ============================================================================

/////>>>>>>> EXTREME FREQUENCY 
// Plot entry/exit markers
// plotshape(entry_signal and is_long,
//     title = "Long Entry Signal",
//     location = location.belowbar,
//     color = color.new(color.green, 0),
//     style = shape.triangleup,
//     size = size.small)

 

plotshape(entry_signal and is_short,
    title = "Short Entry Signal",
    location = location.abovebar,
    color = color.new(color.red, 0),
    style = shape.triangledown,
    size = size.small)

 

plotshape(exit_signal and is_long and strategy.position_size > 0,
    title = "Long Exit Signal",
    location = location.abovebar,
    color = color.new(color.orange, 0),
    style = shape.xcross,
    size = size.tiny)

 

plotshape(exit_signal and is_short and strategy.position_size < 0,
    title = "Short Exit Signal",
    location = location.belowbar,
    color = color.new(color.blue, 0),
    style = shape.xcross,
    size = size.tiny)

 

// Debug: Show signal states in data window
plot(thresh_signal_valid ? 1 : 0, "Threshold A Valid", display = display.data_window)
plot(thresh_signal_valid_B ? 1 : 0, "Threshold B Valid", display = display.data_window)
plot(thresh_signal_valid_C ? 1 : 0, "Threshold C Valid", display = display.data_window)
plot(thresh_signal_valid_D ? 1 : 0, "Threshold D Valid", display = display.data_window)
plot(ext_signal_valid ? 1 : 0, "External A Valid", display = display.data_window)
plot(ext_signal_valid_B ? 1 : 0, "External B Valid", display = display.data_window)
plot(ext_signal_valid_C ? 1 : 0, "External C Valid", display = display.data_window)
plot(ext_signal_valid_D ? 1 : 0, "External D Valid", display = display.data_window)
plot(entry_andA_trigger ? 1 : 0, "Entry AND-A", display = display.data_window)
plot(entry_andB_trigger ? 1 : 0, "Entry AND-B", display = display.data_window)
plot(entry_or_trigger ? 1 : 0, "Entry OR", display = display.data_window)