{
  "manifest_version": 3,
  "name": "TradingView Strategy Optimizer",
  "version": "0.1.0",
  "description": "Automate strategy optimization in TradingView with parameter testing and result analysis",
  "author": "Your Name",

  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "https://www.tradingview.com/*",
    "https://tradingview.com/*"
  ],

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.tradingview.com/*",
        "https://tradingview.com/*"
      ],
      "js": [
        "utils/logger.js",
        "utils/helpers.js",
        "utils/tradingview.js",
        "content/detector.js",
        "content/extractor.js",
        "content/automator.js",
        "content/injector.js",
        "content/content.js"
      ],
      "css": [
        "ui/panel/panel.css"
      ],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "ui/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "ui/panel/panel.html",
        "ui/modal/modal.html"
      ],
      "matches": [
        "https://www.tradingview.com/*",
        "https://tradingview.com/*"
      ]
    }
  ]
}
